---
// Footer.astro — Pie de página global
---

<footer style="background: var(--color-neutral-dark);" class="pt-12 pb-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Grid de 3 columnas -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 pb-10 border-b border-white/10">

      <!-- Columna 1: Logo + tagline -->
      <div>
        <a href="/" class="inline-block mb-3">
          <span
            class="text-white font-bold text-2xl"
            style="font-family: var(--font-display);"
          >
            Pablo Borrás
          </span>
        </a>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
          Médico Veterinario · Speaker · Autor.<br />
          Formación, referencia clínica y marca profesional al servicio del ecosistema veterinario.
        </p>
        <!-- Redes sociales -->
        <div class="flex gap-4 mt-5">
          <!-- Instagram -->
          <a
            href="https://www.instagram.com/pablojborras"
            aria-label="Instagram de Pablo Borrás"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-opacity hover:opacity-70 inline-flex items-center justify-center"
            style="color: var(--color-accent-light); min-width: 44px; min-height: 44px;"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <!-- YouTube -->
          <a
            href="https://www.youtube.com/@pabloborras"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube de Pablo Borrás"
            class="transition-opacity hover:opacity-70 inline-flex items-center justify-center"
            style="color: var(--color-accent-light); min-width: 44px; min-height: 44px;"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.97C18.88 4 12 4 12 4s-6.88 0-8.59.45A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 0 0 1.95-1.97A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a
            href="https://www.linkedin.com/in/pablojborras"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn de Pablo Borrás"
            class="transition-opacity hover:opacity-70 inline-flex items-center justify-center"
            style="color: var(--color-accent-light); min-width: 44px; min-height: 44px;"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Columna 2: Navegación rápida -->
      <div>
        <h3
          class="text-white font-semibold text-sm uppercase tracking-wider mb-4"
          style="font-family: var(--font-body);"
        >
          Navegación
        </h3>
        <ul class="space-y-2">
          {[
            { label: 'Inicio', href: '/' },
            { label: 'Para tutores', href: '/tutores' },
            { label: 'Para veterinarios', href: '/veterinarios' },
            { label: 'Para empresas', href: '/empresas' },
            { label: 'Eventos', href: '/eventos' },
            { label: 'Videos', href: '/videos' },
            { label: 'Contacto', href: '/contacto' },
          ].map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors hover:text-white"
                style="color: var(--color-text-muted); text-decoration: none;"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 3: Contacto directo -->
      <div>
        <h3
          class="text-white font-semibold text-sm uppercase tracking-wider mb-4"
          style="font-family: var(--font-body);"
        >
          Contacto directo
        </h3>
        <p class="text-sm mb-3" style="color: var(--color-text-muted);">
          ¿Tenés una consulta o propuesta profesional?
        </p>
        <a
          href="mailto:consultas.borras@gmail.com"
          class="text-sm font-medium transition-colors hover:text-white"
          style="color: var(--color-accent-light); text-decoration: none;"
        >
          consultas.borras@gmail.com
        </a>
        <div class="mt-5">
          <a
            href="/contacto"
            class="inline-block text-sm font-semibold px-5 py-2 rounded-md transition-opacity hover:opacity-80"
            style="background: var(--color-accent); color: #fff; text-decoration: none; border-radius: var(--radius);"
          >
            Ir al formulario de contacto
          </a>
        </div>
      </div>

    </div>

    <!-- Mini-CTA -->
    <div class="py-8 text-center border-t border-white/10">
      <p class="text-sm font-medium mb-3" style="color: rgba(255,255,255,0.55);">
        ¿Querés trabajar con Pablo?
      </p>
      <a
        href="/contacto"
        class="inline-flex items-center gap-1 text-sm font-semibold transition-opacity hover:opacity-75"
        style="color: var(--color-accent-light); text-decoration: none;"
      >
        Escribime →
      </a>
    </div>

    <!-- Copyright -->
    <div class="pb-4 text-center text-xs" style="color: var(--color-text-muted);">
      © 2025 Pablo Borrás · Todos los derechos reservados.
    </div>

  </div>
</footer>
