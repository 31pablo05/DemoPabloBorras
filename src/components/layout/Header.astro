---
// Header.astro — Navegación principal sticky con glassmorphism al scroll
import MobileMenu from './MobileMenu.jsx';

const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Para tutores', href: '/tutores' },
  { label: 'Para veterinarios', href: '/veterinarios' },
  { label: 'Para empresas', href: '/empresas' },
  { label: 'Eventos', href: '/eventos' },
  { label: 'Contacto', href: '/contacto' },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full"
  style="background: var(--color-primary); transition: background 0.3s, box-shadow 0.3s;"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo + subtítulo -->
      <a href="/" class="flex flex-col leading-tight group" aria-label="Pablo Borrás – Inicio">
        <span
          class="text-white font-bold text-xl md:text-2xl"
          style="font-family: var(--font-display);"
        >
          Pablo Borrás
        </span>
        <span
          class="text-xs tracking-wide"
          style="color: var(--color-accent-light); font-family: var(--font-body);"
        >
          Méd. Veterinario · Speaker · Autor
        </span>
      </a>

      <!-- Navegación desktop -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Navegación principal">
        {navLinks.map(link => (
          <a href={link.href} class="nav-link text-sm font-medium">
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Menú móvil (React Island) -->
      <div class="md:hidden">
        <MobileMenu links={navLinks} client:load />
      </div>

    </div>
  </div>
</header>

<!-- Script glassmorphism al scroll -->
<script>
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      header?.classList.add('header-glass');
    } else {
      header?.classList.remove('header-glass');
    }
  });
</script>
