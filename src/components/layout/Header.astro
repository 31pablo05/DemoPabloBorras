---
// Header.astro — Navegación principal sticky con glassmorphism al scroll
import MobileMenu from './MobileMenu.jsx';

const navLinks = [
  { label: 'Inicio', href: '/' },
  { label: 'Para tutores', href: '/tutores' },
  { label: 'Para veterinarios', href: '/veterinarios' },
  { label: 'Para empresas', href: '/empresas' },
  { label: 'Eventos', href: '/eventos' },
  { label: 'Contacto', href: '/contacto' },
];

// En desktop el "Contacto" se muestra como CTA separado, no como pill
const desktopNavLinks = navLinks.filter(l => l.href !== '/contacto');
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full header-entry"
>
  <!-- Línea de acento verde en el top -->
  <div
    aria-hidden="true"
    style="
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, #2D9B73 0%, #4ECBA1 50%, #2D9B73 100%);
      z-index: 1;
    "
  ></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" style="position: relative; z-index: 1;">
    <div class="flex items-center justify-between h-16 md:h-[68px]">

      <!-- ── LOGO ── -->
      <a href="/" class="logo-group" aria-label="Pablo Borrás – Inicio">
        <!-- Logo imagen -->
        <img
          src="/imagenes/logo/log3.png"
          alt="Pablo Borrás"
          style="height: 48px; width: auto; object-fit: contain; display: block; flex-shrink: 0;"
          loading="eager"
        />

        <!-- Separador vertical -->
        <div
          aria-hidden="true"
          style="
            width: 1px;
            height: 28px;
            background: rgba(255,255,255,0.15);
            border-radius: 1px;
            flex-shrink: 0;
          "
        ></div>

        <!-- Texto del logo -->
        <div class="flex flex-col" style="gap: 3px; line-height: 1;">
          <span
            style="
              font-family: var(--font-display);
              font-size: 1.1rem;
              font-weight: 700;
              color: #ffffff;
              letter-spacing: -0.01em;
            "
          >Pablo Borrás</span>
          <span
            style="
              font-family: var(--font-body);
              font-size: 0.625rem;
              font-weight: 500;
              color: var(--color-accent-light);
              letter-spacing: 0.07em;
              text-transform: uppercase;
              opacity: 0.85;
            "
          >Vet. Especialista · Speaker · Autor</span>
        </div>
      </a>

      <!-- ── NAV DESKTOP ── -->
      <nav class="hidden md:flex items-center gap-0.5" aria-label="Navegación principal">
        {desktopNavLinks.map(link => (
          <a
            href={link.href}
            class="nav-pill"
            data-nav-href={link.href}
            style="letter-spacing: 0.01em;"
          >
            {link.label}
          </a>
        ))}

        <div class="nav-cta-separator" aria-hidden="true"></div>

        <a href="/contacto" class="nav-cta-btn" data-nav-href="/contacto">
          <span>Contactar</span>
          <span class="nav-cta-arrow" aria-hidden="true">→</span>
        </a>
      </nav>

      <!-- ── MENÚ MÓVIL ── -->
      <div class="md:hidden">
        <MobileMenu links={navLinks} client:load />
      </div>

    </div>
  </div>
</header>

<script>
  // ── Glassmorphism al scroll ──────────────────────────────
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      header?.classList.add('header-glass');
    } else {
      header?.classList.remove('header-glass');
    }
  }, { passive: true });

  // ── Marcar enlace activo según pathname ──────────────────
  const path = window.location.pathname.replace(/\/$/, '') || '/';
  document.querySelectorAll<HTMLAnchorElement>('[data-nav-href]').forEach(link => {
    const href = link.getAttribute('data-nav-href')?.replace(/\/$/, '') || '/';
    const isHome = href === '' || href === '/';
    const matches = isHome ? path === '/' : path === href || path.startsWith(href + '/');
    if (matches) {
      link.classList.add('active');
    }
  });
</script>
