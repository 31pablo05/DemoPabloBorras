---
// Button.astro — Componente reutilizable de botón
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: extraClass = '',
} = Astro.props;

const sizeStyles = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-base',
};

const variantStyles = {
  primary:   'bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-light)] hover:text-[var(--color-neutral-dark)]',
  secondary: 'bg-white text-[var(--color-primary)] hover:bg-gray-100',
  outline:   'border-2 border-white text-white hover:bg-white/10',
};

const baseStyle = `inline-flex items-center justify-center font-semibold transition-all duration-200 rounded-[var(--radius)] ${sizeStyles[size]} ${variantStyles[variant]} ${extraClass}`;
---

{href ? (
  <a
    href={href}
    class={baseStyle}
    {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
  >
    <slot />
  </a>
) : (
  <button class={baseStyle}>
    <slot />
  </button>
)}
