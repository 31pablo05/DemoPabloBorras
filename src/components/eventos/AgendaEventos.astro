---
// AgendaEventos.astro — Agenda completa con timeline vertical y separación por estado
import { eventos } from '../../data/eventos.js';
import SectionTitle from '../ui/SectionTitle.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

// Colores por tipo de evento
const tipoColor = {
  Congreso: 'blue',
  Jornada:  'orange',
  Workshop: 'green',
  Simposio: 'purple',
};

// Ordenar por fecha ascendente
const hoy = new Date();
const sorted = [...eventos].sort((a, b) => new Date(a.fecha) - new Date(b.fecha));

// Separar próximos vs pasados
const proximos = sorted.filter(e => new Date(e.fecha + 'T12:00:00') >= hoy);
const pasados  = sorted.filter(e => new Date(e.fecha + 'T12:00:00') < hoy).reverse(); // más reciente primero

// Helper: formatear fecha larga → "15 de agosto de 2025"
function formatFechaLarga(fechaStr) {
  const meses = [
    'enero','febrero','marzo','abril','mayo','junio',
    'julio','agosto','septiembre','octubre','noviembre','diciembre'
  ];
  const d = new Date(fechaStr + 'T12:00:00');
  return `${d.getDate()} de ${meses[d.getMonth()]} de ${d.getFullYear()}`;
}

// Helper: día y mes corto
function diaNum(fechaStr) {
  return new Date(fechaStr + 'T12:00:00').getDate().toString().padStart(2,'0');
}
function mesCorto(fechaStr) {
  const meses = ['ENE','FEB','MAR','ABR','MAY','JUN','JUL','AGO','SEP','OCT','NOV','DIC'];
  return meses[new Date(fechaStr + 'T12:00:00').getMonth()];
}
---

<section class="py-20" style="background: var(--color-neutral-light);">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- ==================== PRÓXIMOS EVENTOS ==================== -->
    {proximos.length > 0 && (
      <>
        <SectionTitle
          title="Próximos eventos"
          subtitle="Agenda 2025"
        />

        <div class="space-y-6 mb-16 relative">
          <!-- Línea vertical decorativa -->
          <div
            class="absolute left-16 top-0 bottom-0 w-0.5 hidden md:block"
            style="background: linear-gradient(to bottom, var(--color-accent), transparent);"
            aria-hidden="true"
          ></div>

          {proximos.map(evento => (
            <div class="flex gap-0 md:gap-6 items-start">
              <!-- Fecha a la izquierda -->
              <div
                class="hidden md:flex flex-col items-center justify-center shrink-0 w-14 h-16 rounded-xl text-white z-10"
                style="background: var(--color-primary);"
              >
                <span class="text-xl font-bold leading-none" style="font-family: var(--font-display);">
                  {diaNum(evento.fecha)}
                </span>
                <span class="text-xs font-semibold tracking-widest" style="color: var(--color-accent-light);">
                  {mesCorto(evento.fecha)}
                </span>
              </div>

              <!-- Punto de timeline -->
              <div
                class="hidden md:block shrink-0 w-3 h-3 rounded-full mt-6 z-10"
                style="background: var(--color-accent);"
                aria-hidden="true"
              ></div>

              <!-- Contenido del evento -->
              <div
                class="flex-1 bg-white rounded-2xl p-6 card-lift"
                style="box-shadow: var(--shadow); border-radius: var(--radius);"
              >
                <div class="flex flex-wrap items-center gap-3 mb-3">
                  <Badge label={evento.tipo} color={tipoColor[evento.tipo] || 'gray'} />
                  <span class="text-xs" style="color: var(--color-text-muted);">
                    📍 {evento.ciudad}
                  </span>
                  <span class="text-xs md:hidden" style="color: var(--color-text-muted);">
                    🗓 {formatFechaLarga(evento.fecha)}
                  </span>
                </div>

                <h3
                  class="text-lg font-bold mb-2"
                  style="font-family: var(--font-display); color: var(--color-text);"
                >
                  {evento.nombre}
                </h3>
                <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-muted);">
                  {evento.descripcion}
                </p>

                <a
                  href="/contacto?tab=eventos"
                  class="text-sm font-semibold transition-colors hover:underline"
                  style="color: var(--color-accent); text-decoration: none;"
                >
                  Quiero invitar a Pablo →
                </a>
              </div>
            </div>
          ))}
        </div>
      </>
    )}

    <!-- ==================== EVENTOS PASADOS ==================== -->
    {pasados.length > 0 && (
      <>
        <SectionTitle
          title="Eventos realizados"
          subtitle="Historial"
        />

        <div class="space-y-4">
          {pasados.map(evento => (
            <div
              class="flex gap-4 items-start rounded-2xl p-5 bg-white"
              style="opacity: 0.65; box-shadow: var(--shadow); border-radius: var(--radius);"
            >
              <!-- Fecha pequeña -->
              <div
                class="hidden sm:flex flex-col items-center justify-center shrink-0 w-12 h-12 rounded-lg text-white"
                style="background: var(--color-neutral-mid);"
              >
                <span class="text-base font-bold leading-none">{diaNum(evento.fecha)}</span>
                <span class="text-xs" style="color: var(--color-accent-light);">{mesCorto(evento.fecha)}</span>
              </div>

              <!-- Contenido -->
              <div class="flex-1">
                <div class="flex flex-wrap items-center gap-2 mb-1">
                  <Badge label={evento.tipo} color={tipoColor[evento.tipo] || 'gray'} />
                  <!-- Badge "Finalizado" -->
                  <span
                    class="text-xs font-semibold px-2 py-0.5 rounded-full"
                    style="background: #F3F4F6; color: #6B7280;"
                  >
                    Finalizado
                  </span>
                  <span class="text-xs" style="color: var(--color-text-muted);">📍 {evento.ciudad}</span>
                </div>
                <h4
                  class="font-semibold text-base"
                  style="font-family: var(--font-display); color: var(--color-text);"
                >
                  {evento.nombre}
                </h4>
                <p class="text-sm mt-1" style="color: var(--color-text-muted);">{evento.descripcion}</p>
              </div>
            </div>
          ))}
        </div>
      </>
    )}

    <!-- CTA quiero invitar a Pablo -->
    <div class="mt-14 text-center">
      <Button href="/contacto?tab=eventos" variant="primary" size="lg">
        ¿Querés invitar a Pablo a tu evento? →
      </Button>
    </div>

  </div>
</section>
