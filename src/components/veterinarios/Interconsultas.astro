---
// Interconsultas.astro — Servicio de interconsultas clínicas profesional
import SectionTitle from '../ui/SectionTitle.astro';
import Button from '../ui/Button.astro';

const beneficios = [
  'Respuesta de un especialista con más de 15 años de experiencia clínica.',
  'Análisis detallado del caso: historial, síntomas, diagnósticos diferenciales.',
  'Protocolo de diagnóstico y manejo terapéutico sugerido.',
  'Seguimiento por email hasta la resolución del caso.',
  'Discusión de casos complejos con enfoque evidence-based.',
];

const casosAplica = [
  'Enfermedades vectoriales (Ehrlichia, Babesia, Anaplasma, Dirofilaria, Leishmania)',
  'Infectología canina: moquillo, leptospirosis, parvovirus',
  'Infectología felina: panleucopenia, calicivirus, herpesvirus, VIF/VLFe',
  'Zoonosis: brucelosis canina, tuberculosis bovina en gatos, Strongyloides',
  'Parasitología con diagnóstico molecular',
  'Toxoplasmosis y otras infecciones por protozoos',
  'Diagnóstico diferencial en síndromes febriles o infecciosos complejos',
  'Casos sin diagnóstico con sospecha de causa infecciosa o parasitaria',
];
---

<section class="py-20" style="background: var(--color-neutral-light);">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Título -->
    <SectionTitle
      title="Interconsultas clínicas"
      subtitle="Servicio para profesionales veterinarios"
    />

    <!-- Descripción del servicio -->
    <div class="prose max-w-none mb-8">
      <p class="text-base leading-relaxed" style="color: var(--color-text-muted);">
        El servicio de interconsulta está diseñado para veterinarios que enfrentan casos clínicos desafiantes y necesitan una segunda opinión especializada. Pablo Borrás analiza el caso, el historial clínico del paciente y propone un enfoque diagnóstico y terapéutico detallado basado en evidencia científica actualizada.
      </p>
    </div>

    <!-- Aviso legal destacado -->
    <div
      class="flex gap-4 p-5 rounded-xl mb-10"
      style="background: #FEF3C7; border-left: 4px solid #D97706; border-radius: var(--radius);"
      role="alert"
    >
      <span class="text-2xl shrink-0" aria-hidden="true">⚠️</span>
      <div>
        <p class="font-semibold text-sm" style="color: #92400E;">Aviso importante</p>
        <p class="text-sm mt-1" style="color: #78350F;">
          La interconsulta profesional no reemplaza al veterinario tratante del paciente. Es un complemento de apoyo clínico exclusivo para médicos veterinarios. El diagnóstico y tratamiento definitivo corresponde únicamente al profesional a cargo del caso.
        </p>
      </div>
    </div>

    <!-- Grid: Beneficios + Casos aplicables -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">

      <!-- Beneficios -->
      <div
        class="bg-white p-8 rounded-2xl"
        style="box-shadow: var(--shadow); border-radius: var(--radius);"
      >
        <h3
          class="text-xl font-bold mb-5"
          style="font-family: var(--font-display); color: var(--color-text);"
        >
          ¿Qué incluye la interconsulta?
        </h3>
        <ul class="space-y-3">
          {beneficios.map(b => (
            <li class="flex items-start gap-3 text-sm" style="color: var(--color-text-muted);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              {b}
            </li>
          ))}
        </ul>
      </div>

      <!-- Casos aplicables -->
      <div
        class="bg-white p-8 rounded-2xl"
        style="box-shadow: var(--shadow); border-radius: var(--radius);"
      >
        <h3
          class="text-xl font-bold mb-5"
          style="font-family: var(--font-display); color: var(--color-text);"
        >
          Especialidades consultadas
        </h3>
        <div class="flex flex-wrap gap-2">
          {casosAplica.map(caso => (
            <span
              class="text-xs font-medium px-3 py-1.5 rounded-full"
              style="background: rgba(45,155,115,0.10); color: var(--color-accent); border: 1px solid rgba(45,155,115,0.2);"
            >
              {caso}
            </span>
          ))}
        </div>
      </div>

    </div>

    <!-- CTA -->
    <div class="mt-12 text-center">
      <Button href="/contacto?tab=interconsultas" variant="primary" size="lg">
        Solicitar interconsulta →
      </Button>
    </div>

  </div>
</section>
