---
// LibroTecnico.astro — Presentación premium del libro (SOLO para sección veterinarios)
// IMPORTANTE: Este componente NO debe usarse en tutores ni en la home principal.
import Button from '../ui/Button.astro';

const beneficios = [
  'Enfermedades infecciosas y parasitarias con énfasis en América Latina y Europa',
  'Abordaje basado en evidencia científica actualizada',
  'Casos clínicos reales con diagnóstico diferencial',
  'Protocolos terapéuticos aplicables a la práctica diaria',
  'Bibliografía internacional de referencia',
];

const publicoObjetivo = [
  'Médicos veterinarios en ejercicio clínico',
  'Residentes y pasantes veterinarios',
  'Docentes universitarios de ciencias veterinarias',
  'Profesionales en formación de posgrado',
];
---

<!-- Sección del libro técnico: gradiente suave y diseño premium -->
<section
  class="py-20"
  style="background: linear-gradient(160deg, var(--color-neutral-light) 0%, #ffffff 100%);"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Badge exclusivo -->
    <div class="flex justify-center mb-10">
      <span
        class="inline-block text-sm font-semibold px-4 py-1.5 rounded-full"
        style="background: rgba(45,155,115,0.12); color: var(--color-accent); border: 1px solid rgba(45,155,115,0.3);"
      >
        📚 Exclusivo para médicos veterinarios
      </span>
    </div>

    <!-- Card premium de ancho completo -->
    <div
      class="rounded-2xl overflow-hidden flex flex-col lg:flex-row"
      style="box-shadow: var(--shadow-lg); border-radius: 16px;"
    >

      <!-- Imagen portada del libro -->
      <div
        class="lg:w-72 shrink-0 flex items-center justify-center p-8"
        style="background: var(--color-primary);"
      >
          <!-- TODO: confirmar nombre del archivo de tapa con Pablo -->
          <img
          src="/imagenes/libro/tapa-libro.jpg"
          alt="Portada del Manual Práctico de Enfermedades Infecciosas y Parasitarias en el Perro — Pablo Borrás"
          class="rounded-lg"
          style="box-shadow: 0 8px 32px rgba(0,0,0,0.3);"
          width="280"
          height="380"
        />
      </div>

      <!-- Contenido -->
      <div class="flex-1 p-8 lg:p-12 bg-white">

        <h2
          class="text-2xl lg:text-3xl font-bold mb-4"
          style="font-family: var(--font-display); color: var(--color-text);"
        >
          Manual Práctico de Enfermedades Infecciosas y Parasitarias en el Perro
        </h2>

        <p class="text-base leading-relaxed mb-8" style="color: var(--color-text-muted);">
          Este libro fue pensado con el objetivo de brindar herramientas, conocimientos y actualizaciones
          sobre diferentes enfermedades producidas por virus, bacterias, hongos, protozoarios y helmintos
          que afectan a los perros de todo el mundo, con mayor énfasis en América Latina y Europa.
        </p>

        <!-- Grid: Público + Beneficios -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

          <!-- Público objetivo -->
          <div>
            <h4
              class="font-semibold text-sm uppercase tracking-wider mb-3"
              style="color: var(--color-text); font-family: var(--font-body);"
            >
              Dirigido a:
            </h4>
            <ul class="space-y-1.5">
              {publicoObjetivo.map(pub => (
                <li class="flex items-start gap-2 text-sm" style="color: var(--color-text-muted);">
                  <span style="color: var(--color-accent);" aria-hidden="true">→</span>
                  {pub}
                </li>
              ))}
            </ul>
          </div>

          <!-- Beneficios -->
          <div>
            <h4
              class="font-semibold text-sm uppercase tracking-wider mb-3"
              style="color: var(--color-text); font-family: var(--font-body);"
            >
              Qué vas a encontrar:
            </h4>
            <ul class="space-y-1.5">
              {beneficios.map(b => (
                <li class="flex items-start gap-2 text-sm" style="color: var(--color-text-muted);">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {b}
                </li>
              ))}
            </ul>
          </div>

        </div>

        <!-- Precio y editorial -->
        <div class="mb-6">
          <p class="text-2xl font-bold" style="font-family: var(--font-display); color: var(--color-text);">104 €</p>
          <p class="text-xs mt-0.5" style="color: var(--color-text-muted);">impuestos incluidos</p>
          <p class="text-xs mt-1" style="color: var(--color-text-muted);">Editorial Multimedica Ediciones Veterinarias</p>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3">
          <Button href="https://libros-veterinaria.multimedica.es/parasitologia/472-manual-practico-de-enfermedades-infecciosas-y-parasitarias-del-perro.html" variant="primary" size="lg" external={true}>
            Obtener el libro →
          </Button>
          <!-- TODO: reemplazar con URLs exactas de ML y Amazon -->
          <a
            href="https://www.mercadolibre.com.ar"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center font-semibold transition-all duration-200 px-6 py-4 text-sm"
            style="border: 2px solid var(--color-accent); color: var(--color-accent); border-radius: var(--radius); text-decoration: none; background: transparent;"
            onmouseover="this.style.background='rgba(45,155,115,0.08)';"
            onmouseout="this.style.background='transparent';"
          >
            Mercado Libre →
          </a>
          <a
            href="https://www.amazon.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center font-semibold transition-all duration-200 px-6 py-4 text-sm"
            style="border: 2px solid #F97316; color: #F97316; border-radius: var(--radius); text-decoration: none; background: transparent;"
            onmouseover="this.style.background='rgba(249,115,22,0.08)';"
            onmouseout="this.style.background='transparent';"
          >
            Amazon →
          </a>
          {/* TODO: reemplazar # con link al PDF de capítulo muestra */}
          <a
            href="#"
            class="inline-flex items-center justify-center font-semibold transition-all duration-200 px-8 py-4 text-base"
            style="border: 2px solid #D1D5DB; color: var(--color-text-muted); border-radius: var(--radius); text-decoration: none; background: transparent;"
            onmouseover="this.style.background='rgba(0,0,0,0.04)';"
            onmouseout="this.style.background='transparent';"
          >
            Descargar capítulo muestra
          </a>
        </div>

      </div>
    </div>

  </div>
</section>
