---
// GaleriaCongresos.astro — Galería de fotos de congresos internacionales
// TODO: reemplazar imágenes en /public/imagenes/congresos/ con las fotos reales
import SectionTitle from '../ui/SectionTitle.astro';

const congresos = [
  {
    foto: '/imagenes/congresos/ecvim-maastricht-2025.jpg',
    evento: 'ECVIM-CA 35th Annual Congress',
    lugar: 'Maastricht, Países Bajos',
    año: '2025',
    rol: 'Póster científico',
  },
  {
    foto: '/imagenes/congresos/waavp-curitiba-2025.jpg',
    evento: 'WAAVP 2025',
    lugar: 'Curitiba, Brasil',
    año: '2025',
    rol: 'Presentación científica',
  },
  {
    foto: '/imagenes/congresos/aveaca-buenos-aires-2025.jpg',
    evento: 'Congreso AVEACA 2025',
    lugar: 'Buenos Aires, Argentina',
    año: '2025',
    rol: '2° Premio mejor caso clínico',
  },
  {
    foto: '/imagenes/congresos/cvdl-guayaquil-2025.jpg',
    evento: 'Congreso Veterinario de León — Guayaquil',
    lugar: 'Guayaquil, Ecuador',
    año: '2025',
    rol: 'Ponente',
  },
  {
    foto: '/imagenes/congresos/civi-iguazu-2025.jpg',
    evento: 'CIVI Congreso Veterinario',
    lugar: 'Iguazú, Argentina',
    año: '2025',
    rol: 'Ponente invitado',
  },
  {
    foto: '/imagenes/congresos/idexx-asuncion-2025.jpg',
    evento: 'Lanzamiento SNAP Tests IDEXX',
    lugar: 'Asunción, Paraguay',
    año: '2025',
    rol: 'Speaker oficial',
  },
  {
    foto: '/imagenes/congresos/hospital-muniz-2025.jpg',
    evento: 'X Congreso Hospital Muñiz',
    lugar: 'Buenos Aires, Argentina',
    año: '2025',
    rol: 'Disertante',
  },
  {
    foto: '/imagenes/congresos/medellin-colombia-2025.jpg',
    evento: 'Jornada de Infectología — Universidad Cooperativa',
    lugar: 'Medellín, Colombia',
    año: '2025',
    rol: 'Ponente',
  },
  {
    foto: '/imagenes/congresos/mendoza-2025.jpg',
    evento: 'Taller Enfermedades Vectoriales — ForVet',
    lugar: 'Mendoza, Argentina',
    año: '2025',
    rol: 'Docente',
  },
];
---

<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <SectionTitle
      title="Presencia internacional"
      subtitle="Congresos y eventos"
    />

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
    >
      {congresos.map((congreso) => (
        <div
          class="reveal rounded-2xl overflow-hidden card-lift"
          style="box-shadow: var(--shadow); border-radius: var(--radius);"
        >
          <!-- Imagen con overlay al hover -->
          <div class="relative" style="aspect-ratio: 4/3; overflow: hidden;">
            <img
              src={congreso.foto}
              alt={`${congreso.evento} — ${congreso.lugar}`}
              class="congreso-img w-full h-full object-cover"
              loading="lazy"
            />
            <!-- Overlay oscuro sutil al hover (CSS) -->
            <div class="congreso-overlay absolute inset-0" style="background: rgba(0,0,0,0); transition: background 0.3s;"></div>
            <!-- Badge año -->
            <span
              class="absolute top-3 right-3 px-2 py-0.5 rounded-full text-xs font-semibold"
              style="background: var(--color-primary); color: #fff; opacity: 0.9;"
            >
              {congreso.año}
            </span>
          </div>

          <!-- Contenido de la card -->
          <div class="p-5">
            <h3
              class="font-bold text-base leading-snug mb-1"
              style="font-family: var(--font-display); color: var(--color-text);"
            >
              {congreso.evento}
            </h3>
            <p class="text-xs mb-3" style="color: var(--color-text-muted);">
              {congreso.lugar}
            </p>
            <!-- Chip de rol -->
            <span
              class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium"
              style="background: rgba(45,155,115,0.1); color: var(--color-accent); border: 1px solid rgba(45,155,115,0.2);"
            >
              {congreso.rol}
            </span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .congreso-card:hover .congreso-img {
    transform: scale(1.04);
    transition: transform 0.4s ease;
  }
  .congreso-img {
    transition: transform 0.4s ease;
  }
  .card-lift:hover .congreso-overlay {
    background: rgba(0, 0, 0, 0.18) !important;
  }
</style>
