---
// SobrePablo.astro — Bloque de presentación y autoridad profesional del home
import Button from '../ui/Button.astro';

const stats = [
  { numero: '+15',  label: 'Años de experiencia clínica' },
  { numero: '+30K', label: 'Seguidores en Instagram' },
  { numero: '+8',   label: 'Países donde disertó' },
  { numero: '+4',   label: 'Artículos científicos publicados' },
];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- ── Columna izquierda: Grid B1 — 2 fotos + tapa libro ── -->
      <div
        class="reveal flex flex-col gap-3"
        style="transition-delay: 0.1s;"
      >

        <!-- Layout mobile: foto principal + mini-row congreso/libro -->
        <div class="flex flex-col gap-3 lg:hidden">
          <!-- Foto principal -->
          <div style="border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-lg); max-height: 340px;">
            <img
              src="/imagenes/perfil/pablo4.png"
              alt="Pablo Borrás — Médico Veterinario, Speaker y Autor"
              class="w-full object-cover object-top"
              style="border-radius: 16px; max-height: 340px;"
              width="480"
              height="340"
            />
          </div>
          <!-- Fila de 2: congreso + libro -->
          <div class="grid grid-cols-2 gap-3" style="height: 160px;">
            <div style="border-radius: 12px; overflow: hidden; box-shadow: var(--shadow);">
              <img
                src="/imagenes/congresos/medellin-colombia-2025.jpg"
                alt="Pablo Borrás en congreso internacional"
                class="w-full h-full object-cover object-center"
                style="border-radius: 12px;"
                loading="lazy"
                width="200"
                height="160"
              />
            </div>
            <a
              href="/veterinarios/libro"
              class="flex items-center justify-center"
              style="
                border-radius: 12px;
                overflow: hidden;
                position: relative;
                background: linear-gradient(160deg, #0a1a5c 0%, #0d2d8a 40%, #1055b0 70%, #1880c9 100%);
                box-shadow: var(--shadow);
              "
            >
              <img
                src="/imagenes/libro/libroport2.png"
                alt="Manual Práctico — Pablo Borrás"
                style="width: 85%; height: 90%; object-fit: contain; border-radius: 4px; box-shadow: 0 4px 16px rgba(0,0,0,0.4);"
                width="130"
                height="144"
              />
            </a>
          </div>
        </div>

        <!-- Grid de 3 celdas: foto grande izquierda + foto congreso + libro (solo desktop) -->
        <div
          class="hidden lg:grid"
          style="
            grid-template-columns: 1.4fr 1fr;
            grid-template-rows: 1fr 1fr;
            gap: 12px;
            height: clamp(520px, 65vw, 720px);
          "
        >

          <!-- Celda 1: Foto principal — ocupa las 2 filas -->
          <div style="grid-row: 1 / 3; position: relative; border-radius: 14px; overflow: hidden; box-shadow: var(--shadow-lg);">
            <img
              src="/imagenes/perfil/pablo4.png"
              alt="Pablo Borrás — Médico Veterinario, Speaker y Autor"
              class="w-full h-full object-cover object-top"
              style="border-radius: 14px;"
              width="320"
              height="420"
            />
          </div>

          <!-- Celda 2: Foto congreso (arriba derecha) -->
          <div style="border-radius: 12px; overflow: hidden; box-shadow: var(--shadow);">
            <img
              src="/imagenes/congresos/medellin-colombia-2025.jpg"
              alt="Pablo Borrás en congreso internacional"
              class="w-full h-full object-cover object-center"
              style="border-radius: 12px;"
              loading="lazy"
              width="200"
              height="175"
            />
          </div>

          <!-- Celda 3: Tapa del libro (abajo derecha) -->
          <a
            href="/veterinarios/libro"
            style="
              border-radius: 12px;
              overflow: hidden;
              position: relative;
              display: flex;
              align-items: center;
              justify-content: center;
              height: 100%;
              background: linear-gradient(160deg, #0a1a5c 0%, #0d2d8a 40%, #1055b0 70%, #1880c9 100%);
              box-shadow: var(--shadow);
              transition: transform 0.2s, box-shadow 0.2s;
            "
            onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='var(--shadow-lg)';"
            onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow)';"
          >
            <img
              src="/imagenes/libro/libroport2.png"
              alt="Manual Práctico de Enfermedades Infecciosas y Parasitarias — Pablo Borrás"
              class="relative"
              style="
                width: 88%;
                height: 90%;
                object-fit: contain;
                border-radius: 6px;
                box-shadow: 0 8px 32px rgba(0,0,0,0.45);
                display: block;
              "
              width="300"
              height="400"
            />
            <!-- Overlay con texto en la parte inferior -->
            <div style="
              position: absolute;
              bottom: 0; left: 0; right: 0;
              padding: 8px 10px;
              background: linear-gradient(to top, rgba(4,13,78,0.85) 0%, transparent 100%);
              border-radius: 0 0 12px 12px;
            ">
              <p style="
                font-family: var(--font-body);
                font-size: 0.6rem;
                font-weight: 700;
                color: var(--color-accent-light);
                letter-spacing: 0.06em;
                text-transform: uppercase;
                margin: 0;
              ">Ver libro →</p>
            </div>
          </a>

        </div>

        <!-- Strip de credencial inferior -->
        <div
          style="
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--color-neutral-light);
            border: 1px solid #c8d8f0;
            border-radius: 10px;
            padding: 10px 14px;
          "
        >
          <span
            style="
              width: 7px;
              height: 7px;
              border-radius: 50%;
              background: #4ade80;
              flex-shrink: 0;
              display: inline-block;
            "
            aria-hidden="true"
          ></span>
          <p
            style="
              font-family: var(--font-body);
              font-size: 0.75rem;
              color: var(--color-text-muted);
              margin: 0;
              line-height: 1.4;
            "
          >
            Editor asociado · <em>Parasites &amp; Vectors</em> — Springer Nature
          </p>
        </div>

      </div>

      <!-- ── Columna derecha: Texto ── -->
      <div>
        <!-- Badge -->
        <div class="reveal" style="transition-delay: 0.1s;">
          <span
            class="inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-5"
            style="background: rgba(24,128,201,0.12); color: var(--color-accent); border: 1px solid rgba(24,128,201,0.28);"
          >
            Médico Veterinario · Speaker · Autor
          </span>
        </div>

        <!-- Título -->
        <div class="reveal" style="transition-delay: 0.15s;">
          <h2
            class="text-3xl md:text-4xl font-bold mb-5 leading-tight"
            style="font-family: var(--font-display); color: var(--color-text);"
          >
            Más de 15 años transformando la medicina veterinaria
          </h2>
        </div>

        <!-- Párrafo bio -->
        <div class="reveal" style="transition-delay: 0.2s;">
          <p class="text-base leading-relaxed mb-8" style="color: var(--color-text-muted);">
            Médico Veterinario egresado de la Universidad de Buenos Aires. Especialista
            en Enfermedades Infecciosas y Parasitarias (CPHV) y Magíster en Prevención y
            Control de Zoonosis (UNNOBA–ANLIS). Editor asociado de <em>Parasites and Vectors</em>
            (Springer Nature). Miembro del TroCCAP Council e ISCAID. Colaborador del
            servicio de Zoopatología del Hospital Francisco J. Muñiz. Actualmente
            cursando el Máster en Medicina Interna de Pequeños Animales en la
            Universidad Autónoma de Barcelona (España). Docente, investigador y speaker
            internacional con presencia en congresos en Argentina, Ecuador, Colombia,
            Uruguay, Brasil, Paraguay, España y Países Bajos.
          </p>
        </div>

        <!-- Stats en grid 2×2 -->
        <div class="reveal grid grid-cols-2 mb-8" style="transition-delay: 0.35s;">
          {stats.map((stat, i) => {
            const isRightCol = i % 2 === 1;
            const isTopRow   = i < 2;
            return (
              <div
                class="p-4"
                style={[
                  isRightCol ? 'border-left: 1px solid #c8d8f0;' : '',
                  !isTopRow  ? 'border-top: 1px solid #c8d8f0;'  : '',,
                ].join(' ')}
              >
                <p
                  class="text-2xl font-bold leading-none"
                  style="font-family: var(--font-display); color: var(--color-accent);"
                  data-count
                >
                  {stat.numero}
                </p>
                <p class="text-xs mt-1" style="color: var(--color-text-muted);">
                  {stat.label}
                </p>
              </div>
            );
          })}
        </div>

        <!-- CTA outline -->
        <div class="reveal" style="transition-delay: 0.4s;">
          <a
            href="/veterinarios"
            class="inline-flex items-center gap-2 px-6 py-3 font-semibold text-sm transition-all duration-200 rounded-lg"
            style="
              border: 2px solid var(--color-accent);
              color: var(--color-accent);
              border-radius: var(--radius);
              text-decoration: none;
              background: transparent;
            "
            onmouseover="this.style.background='var(--color-accent)'; this.style.color='#fff';"
            onmouseout="this.style.background='transparent'; this.style.color='var(--color-accent)';"
          >
            Conocé más sobre Pablo →
          </a>
        </div>

        <!-- Badges de autoridad internacional -->
        <div class="reveal mt-8 pt-6" style="transition-delay: 0.45s; border-top: 1px solid #E5EAED;">
          <p class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-muted);">
            Membresías y reconocimientos
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              href="https://www.troccap.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium transition-opacity hover:opacity-80"
              style="background: rgba(24,128,201,0.10); color: var(--color-accent); border: 1px solid rgba(24,128,201,0.28);"
            >
              🔬 TroCCAP Council Scientific Member
            </a>
            <a
              href="https://www.abcdcatsvets.org"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium transition-opacity hover:opacity-80"
              style="background: rgba(59,130,246,0.08); color: #3B82F6; border: 1px solid rgba(59,130,246,0.2);"
            >
              🐱 ABCD cats &amp; vets Europe
            </a>
            <a
              href="https://www.iscaid.org"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium transition-opacity hover:opacity-80"
              style="background: rgba(139,92,246,0.08); color: #7C3AED; border: 1px solid rgba(139,92,246,0.2);"
            >
              🌐 ISCAID Member
            </a>
            <a
              href="https://www.esccap.org"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium transition-opacity hover:opacity-80"
              style="background: rgba(24,128,201,0.07); color: var(--color-accent); border: 1px solid rgba(24,128,201,0.20);"
            >
              🌿 ESCCAP Member
            </a>
            <a
              href="https://link.springer.com/journal/13071"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium transition-opacity hover:opacity-80"
              style="background: rgba(234,88,12,0.08); color: #C2410C; border: 1px solid rgba(234,88,12,0.2);"
            >
              📖 Editor — Parasites &amp; Vectors
            </a>
            <span
              class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium"
              style="background: rgba(245,158,11,0.08); color: #D97706; border: 1px solid rgba(245,158,11,0.2);"
            >
              🏆 2º Premio mejor caso clínico — AVEACA 2025
            </span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const counters = document.querySelectorAll('[data-count]');
  if (counters.length) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const original = el.textContent.trim();
        const prefix = original.startsWith('+') ? '+' : '';
        const target = parseInt(original.replace(/[^0-9]/g, ''), 10);
        const useThousands = target >= 1000;
        const duration = 1400;
        const start = performance.now();
        function format(n) {
          return useThousands
            ? prefix + n.toLocaleString('de-DE')
            : prefix + n;
        }
        function step(ts) {
          const elapsed = ts - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = format(Math.round(eased * target));
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
        observer.unobserve(el);
      });
    }, { threshold: 0.6 });
    counters.forEach(el => observer.observe(el));
  }
</script>
