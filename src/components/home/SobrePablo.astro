---
// SobrePablo.astro — Bloque de presentación y autoridad profesional del home
import Button from '../ui/Button.astro';

const stats = [
  { numero: '+15',  label: 'Años de experiencia clínica' },
  { numero: '+30K', label: 'Seguidores en Instagram' },
  { numero: '+8',   label: 'Países donde disertó' },
  { numero: '+4',   label: 'Artículos científicos publicados' },
];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- ── Columna izquierda: Grid de fotos + Caption ── -->
      <div class="reveal hidden lg:flex flex-col gap-4" style="transition-delay: 0.1s;">

        <!-- 1. Grid de fotos -->
        <div
          class="hidden lg:grid"
          style="
            grid-template-columns: 1.4fr 1fr;
            grid-template-rows: 1fr 1fr;
            gap: 12px;
            height: clamp(520px, 65vw, 720px);
          "
        >
          <!-- Celda 1: Foto principal — ocupa las 2 filas -->
          <div class="sobrepablo-card" style="grid-row: 1 / 3; position: relative; border-radius: 14px; overflow: hidden; box-shadow: var(--shadow-lg);">
            <img
              src="/imagenes/perfil/pablo4.png"
              alt="Pablo Borrás — Médico Veterinario, Speaker y Autor"
              class="w-full h-full object-cover object-top"
              style="border-radius: 14px;"
              width="320"
              height="420"
            />
          </div>

          <!-- Celda 2: Foto congreso (arriba derecha) -->
          <div class="sobrepablo-card" style="border-radius: 12px; overflow: hidden; box-shadow: var(--shadow);">
            <img
              src="/imagenes/congresos/medellin-colombia-2025.jpg"
              alt="Pablo Borrás en congreso internacional"
              class="w-full h-full object-cover"
              style="border-radius: 12px; object-fit: cover; object-position: center 30%;"
              loading="lazy"
              width="200"
              height="175"
            />
          </div>

          <!-- Celda 3: Tapa del libro (abajo derecha) -->
          <a
            href="/veterinarios/libro"
            class="sobrepablo-card"
            style="
              border-radius: 12px;
              overflow: hidden;
              background: linear-gradient(145deg, var(--color-primary), var(--color-secondary));
              display: flex;
              flex-direction: column;
              align-items: center;
              justify-content: flex-end;
              padding: 0;
              text-decoration: none;
              box-shadow: var(--shadow);
              position: relative;
            "
          >
            <img
              src="/imagenes/libro/libroport2.png"
              alt="Manual Práctico de Enfermedades Infecciosas y Parasitarias — Pablo Borrás"
              style="
                width: 100%;
                height: 100%;
                object-fit: contain;
                object-position: center center;
                display: block;
                padding: 10px 8px 28px;
              "
              width="300"
              height="300"
              loading="lazy"
            />
            <!-- Overlay con texto en la parte inferior -->
            <div style="
              position: absolute;
              bottom: 0;
              left: 0;
              right: 0;
              padding: 8px 10px;
              background: linear-gradient(to top, rgba(4,13,78,0.85), transparent);
              text-align: center;
            ">
              <p style="
                font-family: var(--font-body);
                font-size: 0.6rem;
                font-weight: 700;
                color: var(--color-accent-light);
                letter-spacing: 0.06em;
                text-transform: uppercase;
                margin: 0;
              ">Ver libro →</p>
            </div>
          </a>
        </div>

        <!-- 2. Strip de credencial inferior -->
        <div
          style="
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--color-neutral-light);
            border: 1px solid #c8d8f0;
            border-radius: 10px;
            padding: 10px 14px;
          "
        >
          <span
            style="
              width: 7px;
              height: 7px;
              border-radius: 50%;
              background: #4ade80;
              flex-shrink: 0;
              display: inline-block;
            "
            aria-hidden="true"
          ></span>
          <p
            style="
              font-family: var(--font-body);
              font-size: 0.75rem;
              color: var(--color-text-muted);
              margin: 0;
              line-height: 1.4;
            "
          >
            Editor asociado · <em>Parasites &amp; Vectors</em> — Springer Nature
          </p>
        </div>

      </div>

      <!-- ── Columna derecha: Texto ── -->
      <div>
        <!-- Badge -->
        <div class="reveal" style="transition-delay: 0.1s;">
          <span
            class="inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-5"
            style="background: rgba(24,128,201,0.12); color: var(--color-accent); border: 1px solid rgba(24,128,201,0.28);"
          >
            Médico Veterinario · Speaker · Autor
          </span>
        </div>

        <!-- Título -->
        <div class="reveal" style="transition-delay: 0.15s;">
          <h2
            class="text-3xl md:text-4xl font-bold mb-6 leading-tight"
            style="font-family: var(--font-display); color: var(--color-text);"
          >
            Más de <span style="color: var(--color-accent);">15 años</span> transformando la medicina veterinaria
          </h2>
        </div>

        <!-- Párrafo bio — LEAD (formación y editor) -->
        <div class="reveal" style="transition-delay: 0.2s;">
          <p
            class="text-base leading-relaxed mb-4"
            style="color: #111827; font-weight: 600; font-family: var(--font-body);"
          >
            Médico Veterinario egresado de la Universidad de Buenos Aires. Especialista
            en Enfermedades Infecciosas y Parasitarias (CPHV) y Magíster en Prevención y
            Control de Zoonosis (UNNOBA–ANLIS). Editor asociado de <em>Parasites and Vectors</em>
            (Springer Nature).
          </p>
        </div>

        <!-- Párrafo bio — DETALLE (membresías, máster y países) -->
        <div class="reveal" style="transition-delay: 0.25s;">
          <p
            class="text-sm leading-relaxed mb-8"
            style="color: #374151; font-weight: 400; font-family: var(--font-body);"
          >
            Miembro del TroCCAP Council e ISCAID. Colaborador del
            servicio de Zoopatología del Hospital Francisco J. Muñiz. Actualmente
            cursando el Máster en Medicina Interna de Pequeños Animales en la
            Universidad Autónoma de Barcelona (España). Docente, investigador y speaker
            internacional con presencia en congresos en Argentina, Ecuador, Colombia,
            Uruguay, Brasil, Paraguay, España y Países Bajos.
          </p>
        </div>

        <!-- Imágenes — solo mobile (entre bio y CTA) -->
        <div class="lg:hidden flex flex-col gap-3 mb-8">
          <!-- Foto principal -->
          <div style="border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-lg); max-height: 340px;">
            <img
              src="/imagenes/perfil/pablo4.png"
              alt="Pablo Borrás — Médico Veterinario, Speaker y Autor"
              class="w-full object-cover object-top"
              style="border-radius: 16px; max-height: 340px;"
              width="480"
              height="340"
            />
          </div>
          <!-- Fila de 2: congreso + libro -->
          <div class="grid grid-cols-2 gap-3" style="height: 160px;">
            <div style="border-radius: 12px; overflow: hidden; box-shadow: var(--shadow);">
              <img
                src="/imagenes/congresos/medellin-colombia-2025.jpg"
                alt="Pablo Borrás en congreso internacional"
                class="w-full h-full object-cover object-center"
                style="border-radius: 12px;"
                loading="lazy"
                width="200"
                height="160"
              />
            </div>
            <a
              href="/veterinarios/libro"
              class="flex items-center justify-center"
              style="
                border-radius: 12px;
                overflow: hidden;
                position: relative;
                background: linear-gradient(160deg, #0a1a5c 0%, #0d2d8a 40%, #1055b0 70%, #1880c9 100%);
                box-shadow: var(--shadow);
              "
            >
              <img
                src="/imagenes/libro/libroport2.png"
                alt="Manual Práctico — Pablo Borrás"
                style="width: 85%; height: 90%; object-fit: contain; border-radius: 4px; box-shadow: 0 4px 16px rgba(0,0,0,0.4);"
                width="130"
                height="144"
              />
            </a>
          </div>
          <!-- Badge editor asociado -->
          <div
            style="
              display: flex;
              align-items: center;
              gap: 8px;
              background: var(--color-neutral-light);
              border: 1px solid #c8d8f0;
              border-radius: 10px;
              padding: 10px 14px;
            "
          >
            <span
              style="width: 7px; height: 7px; border-radius: 50%; background: #4ade80; flex-shrink: 0; display: inline-block;"
              aria-hidden="true"
            ></span>
            <p style="font-family: var(--font-body); font-size: 0.75rem; color: var(--color-text-muted); margin: 0; line-height: 1.4;">
              Editor asociado · <em>Parasites &amp; Vectors</em> — Springer Nature
            </p>
          </div>
          <!-- Stats mobile 2x2 -->
          <div class="grid grid-cols-2 gap-3">
            {stats.map((stat) => (
              <div
                class="p-4 text-center"
                style="
                  background: #f7fafd;
                  border: 1px solid #d1e0f0;
                  border-radius: 12px;
                "
              >
                <p
                  class="text-2xl font-bold leading-none mb-2"
                  style="font-family: var(--font-display); color: #1880c9;"
                  data-count
                >
                  {stat.numero}
                </p>
                <p
                  class="text-xs uppercase tracking-wide"
                  style="color: var(--color-text-muted); font-weight: 500; letter-spacing: 0.05em;"
                >
                  {stat.label}
                </p>
              </div>
            ))}
          </div>
        </div>

        <!-- CTA outline -->
        <div class="reveal" style="transition-delay: 0.3s;">
          <a
            href="/sobre-pablo"
            class="inline-flex items-center gap-2 px-6 py-3 font-semibold text-sm transition-all duration-200 rounded-lg"
            style="
              border: 2px solid var(--color-accent);
              color: var(--color-accent);
              border-radius: var(--radius);
              text-decoration: none;
              background: transparent;
            "
            onmouseover="this.style.background='var(--color-accent)'; this.style.color='#fff'; this.querySelector('.cta-arrow').style.transform='translateX(4px)';"
            onmouseout="this.style.background='transparent'; this.style.color='var(--color-accent)'; this.querySelector('.cta-arrow').style.transform='translateX(0)';"
          >
            Conocé más sobre Pablo
            <svg
              class="cta-arrow"
              style="transition: transform 0.2s ease; flex-shrink: 0;"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>

        <!-- Badges de autoridad internacional -->
        <div class="reveal mt-8 pt-6" style="transition-delay: 0.35s; border-top: 1px solid #E5EAED;">
          <p class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-muted);">
            Membresías y reconocimientos
          </p>
          <div class="flex flex-wrap gap-2">

            <!-- TroCCAP — azul -->
            <a
              href="https://www.troccap.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-opacity hover:opacity-80"
              style="border-radius: 8px; background: #EEF4FF; color: #1849A9; border: 0.5px solid #BDCFFA; text-decoration: none;"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              TroCCAP Council Scientific Member
            </a>

            <!-- ABCD — verde -->
            <a
              href="https://www.abcdcatsvets.org"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-opacity hover:opacity-80"
              style="border-radius: 8px; background: #F0FDF4; color: #166534; border: 0.5px solid #86EFAC; text-decoration: none;"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
              ABCD cats &amp; vets Europe
            </a>

            <!-- ISCAID — azul medio -->
            <a
              href="https://www.iscaid.org"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-opacity hover:opacity-80"
              style="border-radius: 8px; background: #EFF6FF; color: #1D4ED8; border: 0.5px solid #93C5FD; text-decoration: none;"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
              ISCAID Member
            </a>

            <!-- ESCCAP — verde oscuro -->
            <a
              href="https://www.esccap.org"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-opacity hover:opacity-80"
              style="border-radius: 8px; background: #F0FDF4; color: #065F46; border: 0.5px solid #6EE7B7; text-decoration: none;"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
              ESCCAP Member
            </a>

            <!-- Editor Parasites & Vectors — naranja -->
            <a
              href="https://link.springer.com/journal/13071"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-opacity hover:opacity-80"
              style="border-radius: 8px; background: #FFF7ED; color: #9A3412; border: 0.5px solid #FED7AA; text-decoration: none;"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
              Editor — Parasites &amp; Vectors
            </a>

            <!-- AVEACA Premio — dorado -->
            <span
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium"
              style="border-radius: 8px; background: #FFFBEB; color: #92400E; border: 0.5px solid #FCD34D;"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
              2º Premio mejor caso clínico — AVEACA 2025
            </span>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const counters = document.querySelectorAll('[data-count]');
  if (counters.length) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const original = el.textContent.trim();
        const prefix = original.startsWith('+') ? '+' : '';
        const target = parseInt(original.replace(/[^0-9]/g, ''), 10);
        const useThousands = target >= 1000;
        const duration = 1400;
        const start = performance.now();
        function format(n) {
          return useThousands
            ? prefix + n.toLocaleString('de-DE')
            : prefix + n;
        }
        function step(ts) {
          const elapsed = ts - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = format(Math.round(eased * target));
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
        observer.unobserve(el);
      });
    }, { threshold: 0.6 });
    counters.forEach(el => observer.observe(el));
  }
</script>

<style>
  .sobrepablo-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .sobrepablo-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(24, 128, 201, 0.15) !important;
  }
</style>
