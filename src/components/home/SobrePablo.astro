---
// SobrePablo.astro — Bloque de presentación y autoridad profesional del home
import Button from '../ui/Button.astro';

const stats = [
  { numero: '+15',    label: 'Años de experiencia clínica' },
  { numero: '+5.000', label: 'Veterinarios formados' },
  { numero: '+20',    label: 'Países donde disertó' },
  { numero: '1',      label: 'Libro técnico publicado' },
];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- ── Columna izquierda: Foto ── -->
      <div
        class="reveal relative flex justify-center lg:justify-start"
        style="transition-delay: 0.1s;"
      >
        <!-- Sombra de color desplazada detrás de la imagen -->
        <div
          class="absolute rounded-2xl"
          style="
            background: var(--color-accent);
            opacity: 0.18;
            border-radius: 16px;
            inset: 0;
            transform: translate(12px, 12px);
          "
          aria-hidden="true"
        ></div>

        <!-- Imagen principal -->
        <div class="relative w-full max-w-sm pb-8 lg:pb-0">
          <!-- TODO: confirmar nombre del archivo de foto de perfil con Pablo -->
          <img
            src="/imagenes/perfil/pablo1.jpg"
            alt="Pablo Borrás — Médico Veterinario, Speaker y Autor"
            class="relative w-full object-cover"
            style="border-radius: 16px; box-shadow: var(--shadow-lg);"
            width="480"
            height="560"
          />

          <!-- Tarjeta flotante superpuesta (esquina inferior izquierda) -->
          <div
            class="absolute bottom-3 -left-3 sm:-bottom-5 sm:-left-5 px-4 sm:px-5 py-3 bg-white"
            style="border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.14);"
          >
            <p
              class="text-3xl font-bold leading-none"
              style="font-family: var(--font-display); color: var(--color-accent);"
            >
              +15
            </p>
            <p class="text-xs mt-0.5" style="color: var(--color-text-muted);">
              años de experiencia
            </p>
          </div>
        </div>
      </div>

      <!-- ── Columna derecha: Texto ── -->
      <div>
        <!-- Badge -->
        <div class="reveal" style="transition-delay: 0.1s;">
          <span
            class="inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-5"
            style="background: rgba(45,155,115,0.12); color: var(--color-accent); border: 1px solid rgba(45,155,115,0.25);"
          >
            Médico Veterinario · Speaker · Autor
          </span>
        </div>

        <!-- Título -->
        <div class="reveal" style="transition-delay: 0.15s;">
          <h2
            class="text-3xl md:text-4xl font-bold mb-5 leading-tight"
            style="font-family: var(--font-display); color: var(--color-text);"
          >
            Más de 15 años transformando la medicina veterinaria
          </h2>
        </div>

        <!-- Párrafo bio -->
        <div class="reveal" style="transition-delay: 0.2s;">
          <p class="text-base leading-relaxed mb-8" style="color: var(--color-text-muted);">
            Médico Veterinario, Especialista en Enfermedades Infecciosas y Parasitarias (CPHV)
            y Magíster en Prevención y Control de Zoonosis (UNNOBA–ANLIS).
            Miembro del TroCCAP Council y de ISCAID. Docente, investigador y speaker internacional
            con presencia en congresos en Argentina, Ecuador, Colombia, Uruguay, Brasil,
            Paraguay, España y Países Bajos.
          </p>
        </div>

        <!-- Stats en grid 2×2 -->
        <div class="reveal grid grid-cols-2 mb-8" style="transition-delay: 0.35s;">
          {stats.map((stat, i) => {
            const isRightCol = i % 2 === 1;
            const isTopRow   = i < 2;
            return (
              <div
                class="p-4"
                style={[
                  isRightCol ? 'border-left: 1px solid #E5EAED;' : '',
                  !isTopRow  ? 'border-top: 1px solid #E5EAED;'  : '',
                ].join(' ')}
              >
                <p
                  class="text-2xl font-bold leading-none"
                  style="font-family: var(--font-display); color: var(--color-accent);"
                  data-count
                >
                  {stat.numero}
                </p>
                <p class="text-xs mt-1" style="color: var(--color-text-muted);">
                  {stat.label}
                </p>
              </div>
            );
          })}
        </div>

        <!-- CTA outline -->
        <div class="reveal" style="transition-delay: 0.4s;">
          <a
            href="/veterinarios"
            class="inline-flex items-center gap-2 px-6 py-3 font-semibold text-sm transition-all duration-200 rounded-lg"
            style="
              border: 2px solid var(--color-accent);
              color: var(--color-accent);
              border-radius: var(--radius);
              text-decoration: none;
              background: transparent;
            "
            onmouseover="this.style.background='var(--color-accent)'; this.style.color='#fff';"
            onmouseout="this.style.background='transparent'; this.style.color='var(--color-accent)';"
          >
            Conocé más sobre Pablo →
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const counters = document.querySelectorAll('[data-count]');
  if (counters.length) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target;
        const original = el.textContent.trim();
        const prefix = original.startsWith('+') ? '+' : '';
        const target = parseInt(original.replace(/[^0-9]/g, ''), 10);
        const useThousands = target >= 1000;
        const duration = 1400;
        const start = performance.now();
        function format(n) {
          return useThousands
            ? prefix + n.toLocaleString('de-DE')
            : prefix + n;
        }
        function step(ts) {
          const elapsed = ts - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = format(Math.round(eased * target));
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
        observer.unobserve(el);
      });
    }, { threshold: 0.6 });
    counters.forEach(el => observer.observe(el));
  }
</script>
