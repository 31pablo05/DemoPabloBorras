---
// VideosPreview.astro — Vista previa de videos de YouTube
import { videos } from '../../data/videos.js';
import SectionTitle from '../ui/SectionTitle.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

// Colores por categoría
const catColor = {
  'Casos Clínicos': 'blue',
  'Educativo':      'green',
  'Conferencias':   'purple',
};

// Permitir mostrar un subconjunto desde props (para home muestra 3, para /videos muestra todos)
interface Props {
  limit?: number;
}
const { limit } = Astro.props;
const videosToShow = limit ? videos.slice(0, limit) : videos;
---

<section style="background: var(--color-neutral-light);" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <SectionTitle
      title="Videos y conferencias"
      subtitle="Contenido audiovisual"
    />

    <!-- Grid de videos -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 mt-2">
      {videosToShow.map((video, index) => (
        <div
          class="reveal bg-white rounded-2xl overflow-hidden card-lift"
          style={`border-radius: var(--radius); box-shadow: var(--shadow); transition-delay: ${index * 0.15}s;`}
        >
          <!-- FACADE: thumbnail + botón play -->
          <div
            class="vid-facade aspect-video w-full relative overflow-hidden"
            data-videoid={video.id}
            data-title={video.titulo}
            style="cursor: pointer;"
          >
            <img
              src={`https://img.youtube.com/vi/${video.id}/hqdefault.jpg`}
              alt={video.titulo}
              class="vid-thumb-img"
              loading="lazy"
              width="480"
              height="270"
              style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center center; transform: scale(1.12); transform-origin: center center;"
            />
            <!-- Overlay oscuro -->
            <div
              class="vid-overlay absolute inset-0 flex items-center justify-center"
              style="background: rgba(2,6,35,0.32); transition: background 0.25s ease;"
            >
              <!-- Botón play custom -->
              <div
                class="play-circle"
                style="
                  width: 56px; height: 56px; border-radius: 50%;
                  background: rgba(255,255,255,0.95);
                  display: flex; align-items: center; justify-content: center;
                  box-shadow: 0 4px 20px rgba(0,0,0,0.35);
                  transition: transform 0.25s ease, background 0.25s ease;
                "
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#1880c9" aria-hidden="true">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
              </div>
            </div>
          </div>

          <!-- Info del video -->
          <div class="p-5">
            <Badge label={video.categoria} color={catColor[video.categoria] || 'gray'} />
            <h3
              class="mt-2 text-base font-semibold leading-snug"
              style="font-family: var(--font-display); color: var(--color-text);"
            >
              {video.titulo}
            </h3>
            <p class="mt-1 text-sm" style="color: var(--color-text-muted);">
              {video.descripcion}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA al canal -->
    <div class="mt-10 flex justify-center">
      <Button href="https://www.youtube.com/@pabloborras" variant="primary" size="md" external={true}>
        Ver canal de YouTube →
      </Button>
    </div>

  </div>
</section>

<style>
  /* Hover lift en cards */
  .vid-card {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .reveal:hover .vid-thumb-img,
  .vid-card:hover .vid-thumb-img {
    transform: scale(1.04);
  }
  .vid-thumb-img {
    transition: transform 0.4s ease;
  }
  /* Oscurece overlay al hover */
  .reveal:hover .vid-overlay {
    background: rgba(2, 6, 35, 0.52) !important;
  }
  /* Agranda play button al hover */
  .reveal:hover .play-circle {
    transform: scale(1.12);
  }
</style>

<script>
  document.querySelectorAll('.vid-facade').forEach((facade) => {
    facade.addEventListener('click', () => {
      const id    = facade.getAttribute('data-videoid');
      const title = facade.getAttribute('data-title') || '';
      const iframe = document.createElement('iframe');
      iframe.src             = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title           = title;
      iframe.allow           = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope';
      iframe.allowFullscreen = true;
      iframe.style.cssText   = 'width:100%;height:100%;border:none;display:block;';
      facade.innerHTML = '';
      facade.style.cursor = 'default';
      facade.appendChild(iframe);
    });
  });
</script>
