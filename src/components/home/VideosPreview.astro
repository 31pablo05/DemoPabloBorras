---
// VideosPreview.astro — Vista previa de videos de YouTube
import { videos } from '../../data/videos.js';
import SectionTitle from '../ui/SectionTitle.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';

// Colores por categoría
const catColor = {
  'Casos Clínicos': 'blue',
  'Educativo':      'green',
  'Conferencias':   'purple',
};

// Permitir mostrar un subconjunto desde props (para home muestra 3, para /videos muestra todos)
interface Props {
  limit?: number;
}
const { limit } = Astro.props;
const videosToShow = limit ? videos.slice(0, limit) : videos;
---

<section style="background: var(--color-neutral-light);" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <SectionTitle
      title="Videos y conferencias"
      subtitle="Contenido audiovisual"
    />

    <!-- Grid de videos -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 mt-2">
      {videosToShow.map((video, index) => (
        <div
          class="reveal bg-white rounded-2xl overflow-hidden card-lift"
          style={`border-radius: var(--radius); box-shadow: var(--shadow); transition-delay: ${index * 0.15}s;`}
        >
          <!-- iframe YouTube o placeholder si el ID no está disponible -->
          <div class="aspect-video w-full">
            {video.id.startsWith('REEMPLAZAR_') ? (
              <div
                class="w-full h-full flex flex-col items-center justify-center gap-3"
                style="background: var(--color-primary); border-radius: var(--radius) var(--radius) 0 0;"
              >
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.97C18.88 4 12 4 12 4s-6.88 0-8.59.45A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 0 0 1.95-1.97A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z" fill="#FF0000"/>
                  <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="#fff"/>
                </svg>
                <p class="text-white font-semibold text-sm" style="font-family: var(--font-display);">Video próximamente</p>
                <p class="text-center text-xs px-6" style="color: rgba(255,255,255,0.5);">Los videos reales se cargarán cuando estén disponibles</p>
              </div>
            ) : (
              <iframe
                src={`https://www.youtube.com/embed/${video.id}`}
                title={video.titulo}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
                class="w-full h-full"
                style="border: none;"
              ></iframe>
            )}
          </div>

          <!-- Info del video -->
          <div class="p-5">
            <Badge label={video.categoria} color={catColor[video.categoria] || 'gray'} />
            <h3
              class="mt-2 text-base font-semibold leading-snug"
              style="font-family: var(--font-display); color: var(--color-text);"
            >
              {video.titulo}
            </h3>
            <p class="mt-1 text-sm" style="color: var(--color-text-muted);">
              {video.descripcion}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA al canal -->
    <div class="mt-10 flex justify-center">
      <Button href="https://www.youtube.com/@pabloborras" variant="primary" size="md" external={true}>
        Ver canal de YouTube →
      </Button>
    </div>

  </div>
</section>
