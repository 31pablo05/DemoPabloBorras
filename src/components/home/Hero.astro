---
// Hero.astro — Sección principal de la homepage con CTAs por audiencia
---

<section
  class="relative overflow-hidden"
  style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-neutral-dark) 100%);"
>
  <!-- Patrón decorativo de puntos sobre el fondo -->
  <div class="dot-pattern absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <!-- Elemento decorativo: círculo de acento superior derecha (float animado) -->
  <div
    class="blob-float absolute top-0 right-0 w-96 h-96 rounded-full opacity-10 pointer-events-none"
    style="background: var(--color-accent); filter: blur(80px); transform: translate(30%, -30%);"
    aria-hidden="true"
  ></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-16 md:py-20 w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">

      <!-- ── IMAGEN — order-2 en mobile = aparece debajo del texto ── -->
      <div class="flex justify-center items-end order-2 md:order-last animate-scale-in delay-300">
        <div class="relative w-full max-w-xs sm:max-w-sm md:max-w-full">
          <!-- Decoración borrosa detrás -->
          <div
            class="absolute -inset-4 rounded-2xl opacity-20"
            style="background: var(--color-accent); filter: blur(30px);"
            aria-hidden="true"
          ></div>
          <img
            src="/imagenes/perfil/pablo2.jpg"
            alt="Pablo Borrás — Médico Veterinario, Speaker y Autor"
            class="relative rounded-3xl object-contain w-full"
            style="box-shadow: var(--shadow-lg); max-height: 560px;"
            width="480"
            height="560"
          />
          <!-- Badge flotante de autoridad -->
          <div
            class="absolute -bottom-3 -left-3 sm:-bottom-4 sm:-left-5 px-4 sm:px-6 py-2 sm:py-3 rounded-xl shadow-lg"
            style="background: var(--color-accent); color: #fff; border-radius: var(--radius);"
          >
            <p class="text-xs font-medium opacity-80">Veterinarios formados</p>
            <p class="text-xl sm:text-2xl font-bold" style="font-family: var(--font-display);">+1.200</p>
          </div>
        </div>
      </div>

      <!-- ── TEXTO — order-1 en mobile = aparece arriba de la imagen ── -->
      <div class="order-1 md:order-first pt-0 md:pt-0">
        <!-- Línea decorativa + nombre -->
        <div class="flex items-start gap-4 mb-5">
          <div
            class="animate-slide-in-left w-1 self-stretch rounded-full mt-1 shrink-0"
            style="background: var(--color-accent); min-height: 48px;"
            aria-hidden="true"
          ></div>
          <div>
            <h1
              class="animate-fade-in-up delay-100 text-4xl sm:text-5xl md:text-6xl text-white font-bold leading-tight"
              style="font-family: var(--font-display);"
            >
              Pablo Borrás
            </h1>
            <p
              class="animate-fade-in-up delay-200 mt-2 text-sm sm:text-base md:text-lg font-medium tracking-wide"
              style="color: var(--color-accent-light); font-family: var(--font-body);"
            >
              Speaker · Autor · Médico Veterinario
            </p>
          </div>
        </div>

        <!-- Párrafo de autoridad -->
        <p
          class="text-white/80 text-sm sm:text-base md:text-lg leading-relaxed mb-8 max-w-lg animate-fade-in-up delay-300"
          style="font-family: var(--font-body);"
        >
          Referente clínico, formador de veterinarios y divulgador científico.<br />
          Más de 15 años acompañando a mascotas, profesionales e instituciones.
        </p>

        <!-- CTAs por audiencia -->
        <div class="flex flex-col sm:flex-row flex-wrap gap-3">
          <!-- CTA tutores -->
          <a
            href="/tutores"
            class="inline-flex items-center justify-center px-6 py-3 rounded-md font-semibold text-sm text-white transition-all duration-200 hover:opacity-90 hover:-translate-y-0.5 animate-fade-in-up delay-400"
            style="background: var(--color-accent); border-radius: var(--radius);"
          >
            🐾 Soy tutor de mascotas
          </a>

          <!-- CTA veterinarios -->
          <a
            href="/veterinarios"
            class="inline-flex items-center justify-center px-6 py-3 rounded-md font-semibold text-sm transition-all duration-200 hover:bg-gray-100 hover:-translate-y-0.5 animate-fade-in-up delay-500"
            style="background: #fff; color: var(--color-primary); border-radius: var(--radius);"
          >
            🩺 Soy veterinario
          </a>

          <!-- CTA empresas -->
          <a
            href="/empresas"
            class="inline-flex items-center justify-center px-6 py-3 rounded-md font-semibold text-sm text-white border-2 border-white transition-all duration-200 hover:bg-white/10 hover:-translate-y-0.5 animate-fade-in-up delay-600"
            style="border-radius: var(--radius);"
          >
            🏢 Represento una empresa
          </a>
        </div>
      </div>

    </div>
  </div>

</section>
