---
// Hero.astro — Sección principal de la homepage con CTAs por audiencia
---

<section
  class="relative overflow-hidden"
  style="
    background:
      radial-gradient(ellipse 80% 65% at 10% 55%, rgba(24,59,127,0.95) 0%, transparent 52%),
      radial-gradient(ellipse 55% 70% at 88% 12%, rgba(24,128,201,0.20) 0%, transparent 48%),
      radial-gradient(ellipse 65% 55% at 50% 100%, rgba(2,6,35,0.85) 0%, transparent 55%),
      linear-gradient(155deg, #020618 0%, #040d4e 35%, #0d1b6e 65%, #040d4e 100%);
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  "
>
  <!-- Patrón decorativo de puntos sobre el fondo -->
  <div class="dot-pattern absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <!-- Imagen de Pablo difuminada — lado izquierdo, detrás de todo -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="z-index: 0;"
    aria-hidden="true"
  >
    <!-- Desktop -->
    <img
      id="hero-bg-pablo"
      src="/imagenes/perfil/pablofondohero2.png"
      alt=""
      class="hidden md:block"
      style="
        position: absolute;
        left: 0;
        top: -12%;
        height: 115%;
        width: 55%;
        object-fit: cover;
        object-position: left top;
        opacity: 0.32;
        filter: blur(0.5px) saturate(0.85);
        -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.5) 45%, transparent 100%);
        mask-image: linear-gradient(to right, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.5) 45%, transparent 100%);
      "
    />
    <!-- Mobile -->
    <img
      src="/imagenes/perfil/fondoheromobile.png"
      alt=""
      class="block md:hidden"
      style="
        position: absolute;
        left: 0;
        top: -10%;
        height: 112%;
        width: 100%;
        object-fit: cover;
        object-position: center top;
        opacity: 0.32;
        filter: blur(0.5px) saturate(0.85);
        -webkit-mask-image: linear-gradient(to right, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.5) 55%, transparent 100%);
        mask-image: linear-gradient(to right, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.5) 55%, transparent 100%);
      "
    />
  </div>

  <!-- Elemento decorativo: círculo de acento superior derecha (float animado) -->
  <div
    class="blob-float absolute top-0 right-0 w-96 h-96 rounded-full opacity-[0.15] pointer-events-none"
    style="background: linear-gradient(135deg, #1880c9, #2d2e6f); filter: blur(80px); transform: translate(30%, -30%);"
    aria-hidden="true"
  ></div>

  <!-- Blob sutil inferior izquierda -->
  <div
    class="absolute bottom-0 left-0 w-72 h-72 rounded-full pointer-events-none"
    style="background: #1a367c; filter: blur(100px); transform: translate(-30%, 30%); opacity: 0.10;"
    aria-hidden="true"
  ></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16 md:py-20 w-full" style="position: relative; z-index: 1;">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">

      <!-- ── IMAGEN — order-2 en mobile = aparece debajo del texto ── -->
      <div class="flex justify-center items-end order-2 md:order-last animate-scale-in hero-float delay-300 relative">
        <div class="w-full max-w-xs sm:max-w-sm md:max-w-full">
          <!-- Glow lateral derecho animado (complementa el glow existente) -->
          <div
            class="hero-img-glow absolute pointer-events-none"
            style="
              left: -20px;
              top: 20%;
              width: 3px;
              height: 55%;
              background: linear-gradient(to bottom, transparent, rgba(91,168,224,0.5), transparent);
              border-radius: 2px;
              filter: blur(3px);
            "
            aria-hidden="true"
          ></div>
          <!-- Decoración borrosa detrás -->
          <div
            class="absolute -inset-4 rounded-full opacity-25"
            style="background: radial-gradient(circle, #1880c9 0%, #5ba8e0 40%, transparent 70%); filter: blur(70px);"
            aria-hidden="true"
          ></div>

          <!-- ── Imagen MOBILE: tarjeta con bordes redondeados y glow ── -->
          <div
            class="block md:hidden relative"
            style="
              border-radius: 20px;
              overflow: hidden;
              box-shadow: 0 0 0 1px rgba(91,168,224,0.25), 0 24px 60px rgba(2,6,35,0.6);
            "
          >
            <img
              src="/imagenes/perfil/pablo2.jpg"
              alt="Pablo Borrás — Médico Veterinario, Speaker y Autor"
              class="w-full object-cover object-top"
              style="
                max-height: 380px;
                display: block;
                filter: brightness(1.04) contrast(1.03);
              "
              width="480"
              height="380"
              loading="eager"
              fetchpriority="high"
            />
            <!-- Degradado inferior para que se integre con el fondo -->
            <div
              style="
                position: absolute;
                bottom: 0; left: 0; right: 0;
                height: 80px;
                background: linear-gradient(to top, rgba(4,13,78,0.75) 0%, transparent 100%);
                pointer-events: none;
              "
              aria-hidden="true"
            ></div>
          </div>

          <!-- ── Imagen DESKTOP: cuerpo entero con mask y fade ── -->
          <div
            class="relative w-full hidden md:block"
            style="
              border-radius: 20px;
              overflow: hidden;
              box-shadow:
                6px 0 48px rgba(24,128,201,0.22),
                0 8px 40px rgba(2,6,35,0.5);
            "
          >
            <img
              src="/imagenes/perfil/pablo2.jpg"
              alt="Pablo Borrás — Médico Veterinario, Speaker y Autor"
              class="w-full"
              loading="eager"
              fetchpriority="high"
              style="
                max-height: 600px;
                object-fit: contain;
                object-position: center bottom;
                display: block;
                -webkit-mask-image:
                  linear-gradient(to bottom, black 40%, rgba(0,0,0,0.6) 72%, transparent 100%),
                  linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
                -webkit-mask-composite: destination-in;
                mask-image:
                  linear-gradient(to bottom, black 40%, rgba(0,0,0,0.6) 72%, transparent 100%),
                  linear-gradient(to right, transparent 0%, black 12%, black 88%, transparent 100%);
                mask-composite: intersect;
                filter: drop-shadow(0 0 40px rgba(24,128,201,0.25)) drop-shadow(0 20px 60px rgba(2,6,35,0.5));
              "
              width="480"
              height="600"
            />
          </div>

          <!-- Badge flotante de especialidad -->
          <div
            class="hero-badge-float absolute bottom-4 -left-4 md:-left-6 px-3 py-2"
            style="
              background: rgba(4, 13, 78, 0.88);
              border: 1px solid rgba(91, 168, 224, 0.4);
              border-radius: 8px;
              backdrop-filter: blur(10px);
              -webkit-backdrop-filter: blur(10px);
              z-index: 10;
            "
            aria-hidden="true"
          >
            <p style="
              font-family: var(--font-body);
              font-size: 0.6rem;
              font-weight: 700;
              letter-spacing: 0.1em;
              text-transform: uppercase;
              color: var(--color-accent-light);
              margin: 0;
              white-space: nowrap;
            ">Esp. Enf. Infecciosas</p>
            <p style="
              font-family: var(--font-body);
              font-size: 0.62rem;
              color: rgba(255,255,255,0.6);
              margin: 2px 0 0;
              white-space: nowrap;
            ">Parasitarias · UBA · UNNOBA</p>
          </div>

          <!-- Glow base de la imagen -->
          <div
            aria-hidden="true"
            style="
              position: absolute;
              bottom: -20px;
              left: 50%;
              transform: translateX(-50%);
              width: 60%;
              height: 80px;
              background: radial-gradient(ellipse, rgba(24,128,201,0.20) 0%, transparent 70%);
              filter: blur(20px);
              pointer-events: none;
            "
          ></div>

        </div>
      </div>

      <!-- ── TEXTO — order-1 en mobile = aparece arriba de la imagen ── -->
      <div class="order-1 md:order-first pt-0 md:pt-0 mt-24 md:mt-0">
        <!-- Línea decorativa + nombre -->
        <div class="flex items-start gap-4 mb-5">
          <div
            class="hero-bar-grow w-1 self-stretch rounded-full mt-1 shrink-0"
            style="background: linear-gradient(to bottom, #1880c9, #5ba8e0); min-height: 48px;"
            aria-hidden="true"
          ></div>
          <div>
            <h1
              class="animate-fade-in-up delay-100 text-4xl sm:text-5xl md:text-6xl font-bold leading-tight"
              style="
                font-family: var(--font-display);
                background: linear-gradient(135deg, #ffffff 0%, #ffffff 55%, #5ba8e0 100%);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
              "
            >
              Pablo Borrás
            </h1>
            <p
              class="animate-fade-in-up delay-200 mt-2"
              style="
                color: var(--color-accent-light);
                font-family: var(--font-body);
                letter-spacing: 0.12em;
                text-transform: uppercase;
                font-size: 0.8rem;
                font-weight: 600;
                opacity: 0.9;
              "
            >
              Speaker · Autor · Médico Veterinario
            </p>
          </div>
        </div>

        <!-- Párrafo de autoridad -->
        <p
          class="text-white/70 text-sm sm:text-base md:text-lg leading-relaxed mb-5 max-w-lg animate-fade-in-up delay-300"
          style="font-family: var(--font-body); letter-spacing: 0.01em; line-height: 1.75;"
        >
          Referente clínico, formador de veterinarios y divulgador científico.<br />
          Más de 15 años acompañando a mascotas, profesionales e instituciones.
        </p>

        <!-- Strip de stats de autoridad (solo desktop) -->
        <div
          class="hidden md:flex items-center gap-7 mb-7 animate-fade-in-up delay-400"
          style="
            border-top: 1px solid rgba(255,255,255,0.15);
            border-bottom: 1px solid rgba(255,255,255,0.15);
            padding: 12px 0;
          "
        >
          <div class="hero-stat text-center flex-shrink-0">
            <p
              class="text-xl font-bold text-white leading-none"
              style="font-family: var(--font-display);"
              data-hero-count="15"
              data-hero-prefix="+"
              data-hero-suffix=""
            >+15</p>
            <p style="font-size: 0.68rem; color: rgba(255,255,255,0.5); margin-top: 4px; font-family: var(--font-body); letter-spacing: 0.06em; text-transform: uppercase;">años</p>
          </div>

          <div style="width: 1px; height: 28px; background: rgba(255,255,255,0.12); flex-shrink: 0;"></div>

          <div class="hero-stat text-center flex-shrink-0">
            <p
              class="text-xl font-bold text-white leading-none"
              style="font-family: var(--font-display);"
              data-hero-count="4"
              data-hero-prefix=""
              data-hero-suffix=""
            >4</p>
            <p style="font-size: 0.68rem; color: rgba(255,255,255,0.5); margin-top: 4px; font-family: var(--font-body); letter-spacing: 0.06em; text-transform: uppercase;">publicaciones</p>
          </div>

          <div style="width: 1px; height: 28px; background: rgba(255,255,255,0.12); flex-shrink: 0;"></div>

          <div class="hero-stat text-center flex-shrink-0">
            <p
              class="text-xl font-bold text-white leading-none"
              style="font-family: var(--font-display);"
              data-hero-count="30"
              data-hero-prefix=""
              data-hero-suffix="K+"
            >30K+</p>
            <p style="font-size: 0.68rem; color: rgba(255,255,255,0.5); margin-top: 4px; font-family: var(--font-body); letter-spacing: 0.06em; text-transform: uppercase;">seguidores</p>
          </div>

          <div style="width: 1px; height: 28px; background: rgba(255,255,255,0.12); flex-shrink: 0;"></div>

          <div class="hero-stat text-center flex-shrink-0">
            <p
              class="text-xl font-bold text-white leading-none"
              style="font-family: var(--font-display);"
              data-hero-count="8"
              data-hero-prefix="+"
              data-hero-suffix=""
            >+8</p>
            <p style="font-size: 0.68rem; color: rgba(255,255,255,0.5); margin-top: 4px; font-family: var(--font-body); letter-spacing: 0.06em; text-transform: uppercase;">países</p>
          </div>
        </div>

        <!-- CTAs por audiencia (solo desktop) -->
        <div class="hidden md:flex flex-row flex-wrap gap-3 animate-fade-in-up delay-400">

          <!-- CTA tutores — blanco -->
          <a
            href="/tutores"
            class="inline-flex items-center gap-2.5 px-6 py-3 font-bold text-sm transition-all duration-200 animate-fade-in-up delay-400"
            style="
              border-radius: 10px;
              background: #ffffff;
              color: #040d4e;
              text-decoration: none;
              box-shadow: 0 2px 12px rgba(255,255,255,0.12);
            "
            onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(255,255,255,0.25)'; this.style.background='#f0f4ff';"
            onmouseout="this.style.transform=''; this.style.boxShadow='0 2px 12px rgba(255,255,255,0.12)'; this.style.background='#ffffff';"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            Soy tutor de mascotas
          </a>

          <!-- CTA veterinarios — celeste -->
          <a
            href="/veterinarios"
            class="inline-flex items-center gap-2.5 px-6 py-3 font-semibold text-sm transition-all duration-200 animate-fade-in-up delay-500"
            style="
              border-radius: 10px;
              background: #1880c9;
              color: #ffffff;
              text-decoration: none;
              box-shadow: 0 2px 12px rgba(24,128,201,0.3);
            "
            onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 24px rgba(24,128,201,0.5)'; this.style.background='#1a90e0';"
            onmouseout="this.style.transform=''; this.style.boxShadow='0 2px 12px rgba(24,128,201,0.3)'; this.style.background='#1880c9';"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
            Soy veterinario
          </a>

          <!-- CTA empresas — outline -->
          <a
            href="/empresas"
            class="inline-flex items-center gap-2 font-medium text-sm transition-all duration-200 animate-fade-in-up delay-600"
            style="
              border-radius: 10px;
              padding: 11px 22px;
              background: transparent;
              color: rgba(255,255,255,0.6);
              text-decoration: none;
              border: 1.5px solid rgba(255,255,255,0.3);
            "
            onmouseover="this.style.transform='translateY(-2px)'; this.style.borderColor='rgba(255,255,255,0.85)'; this.style.color='rgba(255,255,255,0.85)';"
            onmouseout="this.style.transform=''; this.style.borderColor='rgba(255,255,255,0.3)'; this.style.color='rgba(255,255,255,0.6)';"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="7" width="20" height="14" rx="2"/>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
            Represento una empresa →
          </a>

        </div>

        <!-- Indicador de disponibilidad — solo desktop -->
        <div
          class="hidden md:flex items-center gap-2 mt-3 animate-fade-in-up delay-700"
        >
          <span class="avail-dot" aria-hidden="true"></span>
          <span style="font-size: 0.68rem; color: rgba(255,255,255,0.38); font-family: var(--font-body); letter-spacing: 0.04em;">
            Recibiendo consultas · Buenos Aires, Argentina
          </span>
        </div>
      </div>

      <!-- Stats strip mobile — debajo de la imagen -->
      <div
        class="flex md:hidden items-center justify-center gap-4 order-3 w-full px-4"
        style="
          border-top: 1px solid rgba(255,255,255,0.15);
          border-bottom: 1px solid rgba(255,255,255,0.15);
          padding: 12px 0;
        "
      >
        <div class="hero-stat text-center flex-shrink-0">
          <p class="text-xl font-bold text-white leading-none" style="font-family: var(--font-display);" data-hero-count="15" data-hero-prefix="+" data-hero-suffix="">+15</p>
          <p style="font-size: 0.68rem; color: rgba(255,255,255,0.5); margin-top: 4px; font-family: var(--font-body); letter-spacing: 0.06em; text-transform: uppercase;">años</p>
        </div>
        <div style="width: 1px; height: 28px; background: rgba(255,255,255,0.12); flex-shrink: 0;"></div>
        <div class="hero-stat text-center flex-shrink-0">
          <p class="text-xl font-bold text-white leading-none" style="font-family: var(--font-display);" data-hero-count="4" data-hero-prefix="" data-hero-suffix="">4</p>
          <p style="font-size: 0.68rem; color: rgba(255,255,255,0.5); margin-top: 4px; font-family: var(--font-body); letter-spacing: 0.06em; text-transform: uppercase;">publicaciones</p>
        </div>
        <div style="width: 1px; height: 28px; background: rgba(255,255,255,0.12); flex-shrink: 0;"></div>
        <div class="hero-stat text-center flex-shrink-0">
          <p class="text-xl font-bold text-white leading-none" style="font-family: var(--font-display);" data-hero-count="30" data-hero-prefix="" data-hero-suffix="K+">30K+</p>
          <p style="font-size: 0.68rem; color: rgba(255,255,255,0.5); margin-top: 4px; font-family: var(--font-body); letter-spacing: 0.06em; text-transform: uppercase;">seguidores</p>
        </div>
        <div style="width: 1px; height: 28px; background: rgba(255,255,255,0.12); flex-shrink: 0;"></div>
        <div class="hero-stat text-center flex-shrink-0">
          <p class="text-xl font-bold text-white leading-none" style="font-family: var(--font-display);" data-hero-count="8" data-hero-prefix="+" data-hero-suffix="">+8</p>
          <p style="font-size: 0.68rem; color: rgba(255,255,255,0.5); margin-top: 4px; font-family: var(--font-body); letter-spacing: 0.06em; text-transform: uppercase;">países</p>
        </div>
      </div>

      <!-- CTAs por audiencia (solo mobile — debajo de la imagen) -->
      <div class="flex md:hidden flex-col gap-3 order-4 w-full">

        <!-- CTA tutores — blanco -->
        <a
          href="/tutores"
          class="inline-flex items-center justify-center gap-2.5 px-6 py-3 font-bold text-sm"
          style="
            border-radius: 10px;
            background: #ffffff;
            color: #040d4e;
            text-decoration: none;
          "
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          Soy tutor de mascotas
        </a>

        <!-- CTA veterinarios — celeste -->
        <a
          href="/veterinarios"
          class="inline-flex items-center justify-center gap-2.5 px-6 py-3 font-semibold text-sm"
          style="
            border-radius: 10px;
            background: #1880c9;
            color: #ffffff;
            text-decoration: none;
          "
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
          Soy veterinario
        </a>

        <!-- CTA empresas — outline -->
        <a
          href="/empresas"
          class="inline-flex items-center justify-center gap-2 font-medium text-sm"
          style="
            border-radius: 10px;
            padding: 11px 22px;
            background: transparent;
            color: rgba(255,255,255,0.6);
            text-decoration: none;
            border: 1.5px solid rgba(255,255,255,0.3);
          "
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="7" width="20" height="14" rx="2"/>
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
          </svg>
          Represento una empresa →
        </a>

      </div>

    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('[data-hero-count]').forEach((el) => {
        const target = parseInt(el.getAttribute('data-hero-count') || '0', 10);
        const prefix = el.getAttribute('data-hero-prefix') || '';
        const suffix = el.getAttribute('data-hero-suffix') || '';
        let cur = 0;
        const step = Math.max(1, Math.ceil(target / 28));
        const iv = setInterval(() => {
          cur = Math.min(cur + step, target);
          el.textContent = prefix + cur + suffix;
          if (cur >= target) clearInterval(iv);
        }, 45);
      });
    });
  </script>

</section>
