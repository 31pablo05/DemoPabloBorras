---
// pages/contacto.astro — Página de contacto con formulario multi-tab
import Layout from '../layouts/Layout.astro';
import FormularioContacto from '../components/contacto/FormularioContacto.jsx';
---

<Layout
  title="Contacto — Interconsultas, Capacitaciones y Eventos | Pablo Borrás"
  description="Contactá a Pablo Borrás para interconsultas clínicas veterinarias, capacitaciones, invitaciones a eventos o propuestas institucionales."
  noindex={false}
>

  <!-- Hero de contacto -->
  <section
    class="py-20 text-center"
    style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-neutral-dark) 100%);"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1
        class="text-4xl md:text-5xl font-bold text-white mb-4"
        style="font-family: var(--font-display);"
      >
        Hablemos
      </h1>
      <p class="text-white/70 text-lg max-w-xl mx-auto">
        Cada consulta va al destino correcto. Elegí la que corresponde a tu necesidad y te respondo a la brevedad.
      </p>
    </div>
  </section>

  <!-- Sección principal: formulario + info de contacto -->
  <section style="background: var(--color-neutral-light);" class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">

        <!-- Columna formulario (2/3) -->
        <div class="lg:col-span-2">
          <!-- React Island: tabs de contacto -->
          <FormularioContacto client:load />
        </div>

        <!-- Columna info directa (1/3) -->
        <div class="space-y-6">

          <!-- Tarjeta contacto directo -->
          <div
            class="bg-white rounded-2xl p-6"
            style="box-shadow: var(--shadow); border-radius: var(--radius);"
          >
            <h3
              class="text-lg font-bold mb-4"
              style="font-family: var(--font-display); color: var(--color-text);"
            >
              Contacto directo
            </h3>
            <p class="text-sm mb-2" style="color: var(--color-text-muted);">Email profesional:</p>
            <a
              href="mailto:consultas.borras@gmail.com"
              class="text-sm font-semibold block mb-5 hover:underline"
              style="color: var(--color-accent);"
            >
              consultas.borras@gmail.com
            </a>

            <p class="text-xs" style="color: var(--color-text-muted);">
              Tiempo de respuesta habitual: <strong>24 a 48 hs hábiles.</strong>
            </p>
          </div>

          <!-- Redes sociales -->
          <div
            class="bg-white rounded-2xl p-6"
            style="box-shadow: var(--shadow); border-radius: var(--radius);"
          >
            <h3
              class="text-lg font-bold mb-4"
              style="font-family: var(--font-display); color: var(--color-text);"
            >
              Redes sociales
            </h3>
            <div class="space-y-3">
              <a
                href="https://www.instagram.com/pablojborras"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-sm font-medium transition-colors hover:opacity-80"
                style="color: var(--color-text); text-decoration: none;"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E4405F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <circle cx="12" cy="12" r="4"/>
                  <circle cx="17.5" cy="6.5" r="0.5" fill="#E4405F"/>
                </svg>
                @pabloborras_vet
              </a>
              <a
                href="https://www.youtube.com/@pabloborras"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-sm font-medium transition-colors hover:opacity-80"
                style="color: var(--color-text); text-decoration: none;"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF0000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.97C18.88 4 12 4 12 4s-6.88 0-8.59.45A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.4a2.78 2.78 0 0 0 1.95-1.97A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                  <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="#FF0000" stroke="none"/>
                </svg>
                Canal de YouTube
              </a>
              <a
                href="#"
                class="flex items-center gap-3 text-sm font-medium transition-colors hover:opacity-80"
                style="color: var(--color-text); text-decoration: none;"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0A66C2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect x="2" y="9" width="4" height="12"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
                LinkedIn profesional
              </a>
            </div>
          </div>

          <!-- Nota de privacidad -->
          <p class="text-xs leading-relaxed" style="color: var(--color-text-muted);">
            Tu información es confidencial y solo se usará para responder tu consulta. No realizamos envíos comerciales no solicitados.
          </p>

        </div>
      </div>
    </div>
  </section>

</Layout>
