---
import Layout from '../layouts/Layout.astro';
import VideosPreview from '../components/home/VideosPreview.astro';

const categorias = [
  {
    titulo: 'Para tutores de mascotas',
    descripcion: 'Divulgación científica, consejos de salud y prevención para dueños de perros y gatos.',
    videos: [
      {
        id: 'C_lp1A9PlAg',
        titulo: 'Consejos de prevención de parásitos para dueños de mascotas',
        canal: 'YouTube',
      },
      {
        id: 'z518tUU_pFM',
        titulo: 'Parvovirus y Distemper canino: lo que todo tutor debe saber',
        canal: 'YouTube',
      },
    ],
  },
  {
    titulo: 'Para veterinarios',
    descripcion: 'Clases, conferencias y actualizaciones clínicas para profesionales.',
    videos: [
      {
        id: 'z518tUU_pFM',
        titulo: 'Parvovirus y Distemper canino: una mirada desde la clínica',
        canal: 'YouTube',
      },
      {
        id: 'vaWswhnXQsA',
        titulo: 'Biogal Academy — Micoplasmas hemotropicos en gatos: ¿qué hay de nuevo?',
        canal: 'YouTube',
      },
      {
        id: 'wyBBOrjNaxM',
        titulo: 'Dirofilariosis como enfermedad zoonótica: Puntos claves',
        canal: 'YouTube',
      },
    ],
  },
];
---

<Layout
  title="Videos — Pablo Borrás Veterinario"
  description="Videos educativos y conferencias de Pablo Borrás sobre enfermedades infecciosas y parasitarias en perros y gatos. Para veterinarios y tutores de mascotas."
>

  <!-- Hero -->
  <section
    class="py-20 text-center"
    style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-neutral-dark) 100%);"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-5xl mb-6">▶️</div>
      <h1
        class="text-4xl md:text-5xl font-bold text-white mb-4"
        style="font-family: var(--font-display);"
      >
        Videos
      </h1>
      <p class="text-white/70 text-lg">
        Conferencias, actualizaciones clínicas y contenido educativo.
      </p>
    </div>
  </section>

  <!-- Videos grid -->
  <section class="py-20" style="background: var(--color-neutral-light);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      {categorias.map(cat => (
        <div class="mb-16">
          <div class="mb-8">
            <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--color-accent);">
              {cat.descripcion}
            </p>
            <h2 class="text-2xl font-bold" style="font-family: var(--font-display); color: var(--color-text);">
              {cat.titulo}
            </h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {cat.videos.map(v => (
              <div class="bg-white overflow-hidden" style="border-radius: var(--radius); box-shadow: var(--shadow);">
                <div
                class="vid-facade-page aspect-video relative overflow-hidden"
                data-videoid={v.id}
                data-title={v.titulo}
                style="cursor: pointer; border-radius: var(--radius) var(--radius) 0 0;"
              >
                <img
                  src={`https://img.youtube.com/vi/${v.id}/hqdefault.jpg`}
                  alt={v.titulo}
                  loading="lazy"
                  class="w-full h-full object-cover"
                  width="480"
                  height="270"
                />
                <div style="position:absolute;inset:0;background:rgba(2,6,35,0.32);display:flex;align-items:center;justify-content:center;">
                  <div style="width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,0.95);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,0.3);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="#1880c9" aria-hidden="true">
                      <polygon points="5 3 19 12 5 21 5 3"/>
                    </svg>
                  </div>
                </div>
              </div>
                <div class="p-4">
                  <p class="text-sm font-semibold" style="color: var(--color-text);">{v.titulo}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

      <!-- CTA canal -->
      <div class="text-center mt-8">
        <a
          href="https://www.youtube.com/@pabloborras"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 font-semibold text-sm text-white transition-all hover:opacity-90"
          style="background: #FF0000; border-radius: var(--radius); text-decoration: none;"
        >
          Ver canal completo en YouTube →
        </a>
      </div>

    </div>
  </section>

<script>
  document.querySelectorAll('.vid-facade-page').forEach((facade) => {
    facade.addEventListener('click', () => {
      const id    = facade.getAttribute('data-videoid');
      const title = facade.getAttribute('data-title') || '';
      const iframe = document.createElement('iframe');
      iframe.src             = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
      iframe.title           = title;
      iframe.allow           = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope';
      iframe.allowFullscreen = true;
      iframe.style.cssText   = 'width:100%;height:100%;border:none;display:block;';
      facade.innerHTML = '';
      facade.style.cursor = 'default';
      facade.appendChild(iframe);
    });
  });
</script>
</Layout>
