---
// pages/veterinarios/index.astro — Hub para veterinarios con 3 subsecciones y datos de autoridad
import Layout from '../../layouts/Layout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import Button from '../../components/ui/Button.astro';

const subsecciones = [
  {
    href: '/veterinarios/interconsultas',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
    </svg>`,
    titulo: 'Interconsultas clínicas',
    descripcion: 'Segunda opinión especializada para casos complejos. Análisis detallado con enfoque evidence-based.',
    cta: 'Ver interconsultas',
  },
  {
    href: '/veterinarios/capacitaciones',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
      <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
    </svg>`,
    titulo: 'Capacitaciones',
    descripcion: 'Enfermedades vectoriales, infectología canina y felina, zoonosis y parasitología. Presenciales, online e híbridas. Charlas, workshops, jornadas y congresos.',
    cta: 'Ver capacitaciones',
  },
  {
    href: '/veterinarios/libro',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
    </svg>`,
    titulo: 'Libro técnico',
    descripcion: 'Manual Práctico de Enfermedades Infecciosas y Parasitarias en el Perro. Publicado por Multimedica Ediciones Veterinarias. Herramienta de referencia clínica basada en evidencia científica.',
    cta: 'Ver el libro',
  },
];

const stats = [
  { numero: '+15',  label: 'Años de experiencia clínica' },
  { numero: '+30K', label: 'Seguidores en Instagram' },
  { numero: '+8',   label: 'Países donde disertó' },
  { numero: '1',    label: 'Libro técnico publicado' },
];
---

<Layout
  title="Para veterinarios — Interconsultas, Capacitaciones y Libro | Pablo Borrás"
  description="Interconsultas clínicas especializadas en infectología, capacitaciones en enfermedades vectoriales y libro técnico para médicos veterinarios. Por Pablo Borrás MSc."
>

  <!-- Hero secundario -->
  <section
    class="py-20"
    style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-neutral-dark) 100%);"
  >
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div
        class="inline-block text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6"
        style="background: rgba(78,203,161,0.15); color: var(--color-accent-light); border: 1px solid rgba(78,203,161,0.3);"
      >
        Espacio exclusivo para profesionales
      </div>
      <h1
        class="text-4xl md:text-5xl font-bold text-white mb-4"
        style="font-family: var(--font-display);"
      >
        Para veterinarios y profesionales
      </h1>
      <p class="text-white/75 text-lg max-w-2xl mx-auto">
        Herramientas diseñadas para elevar el estándar de tu ejercicio profesional: interconsultas, formación continua y material de referencia clínica.
      </p>
    </div>
  </section>

  <!-- 3 Cards de subsecciones -->
  <section style="background: var(--color-neutral-light);" class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <SectionTitle
        title="¿Qué necesitás?"
        subtitle="Servicios para colegas"
        centered={true}
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-2">
        {subsecciones.map(sub => (
          <a
            href={sub.href}
            class="card-lift group block bg-white rounded-2xl p-8 no-underline"
            style="border-radius: var(--radius); box-shadow: var(--shadow); text-decoration: none; border-top: 3px solid transparent; transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;"
            onmouseover="this.style.borderTopColor='var(--color-accent)'"
            onmouseout="this.style.borderTopColor='transparent'"
          >
            <div
              class="mb-5 w-14 h-14 flex items-center justify-center rounded-xl"
              style="color: var(--color-accent); background: rgba(45,155,115,0.08);"
              set:html={sub.icon}
            />
            <h2
              class="text-xl font-bold mb-3"
              style="font-family: var(--font-display); color: var(--color-text);"
            >
              {sub.titulo}
            </h2>
            <p class="text-sm leading-relaxed mb-6" style="color: var(--color-text-muted);">
              {sub.descripcion}
            </p>
            <span class="text-sm font-semibold group-hover:underline" style="color: var(--color-accent);">
              {sub.cta} →
            </span>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- Bloque de autoridad con stats -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Texto de autoridad -->
        <div>
          <SectionTitle
            title="Trayectoria que respalda"
            subtitle="Autoridad clínica"
          />
          <p class="text-base leading-relaxed mb-4" style="color: var(--color-text-muted);">
            Pablo Borrás construyó su autoridad profesional en la práctica clínica diaria, la investigación continua y una vocación genuina por la formación de colegas.
          </p>
          <p class="text-base leading-relaxed mb-4" style="color: var(--color-text-muted);">
            Hoy es un referente reconocido en el ecosistema veterinario argentino: presente en los principales congresos, con publicaciones especializadas y miles de colegas formados en sus programas.
          </p>
          <ul class="space-y-1.5 text-sm" style="color: var(--color-text-muted);">
            <li class="flex items-start gap-2"><span style="color: var(--color-accent);">▸</span> Editor asociado de <em>Parasites &amp; Vectors</em> — Springer Nature</li>
            <li class="flex items-start gap-2"><span style="color: var(--color-accent);">▸</span> Colaborador del servicio de Zoopatología, Hospital Francisco J. Muñiz</li>
            <li class="flex items-start gap-2"><span style="color: var(--color-accent);">▸</span> Candidato a Magíster en Medicina Interna — Fac. Veterinaria, UAB (España)</li>
            <li class="flex items-start gap-2"><span style="color: var(--color-accent);">▸</span> Miembro de TroCCAP, ISCAID y ESCCAP</li>
          </ul>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-6">
          {stats.map(stat => (
            <div
              class="p-6 rounded-2xl text-center"
              style="background: var(--color-neutral-light); border-radius: var(--radius);"
            >
              <p
                class="text-3xl font-bold mb-1"
                style="font-family: var(--font-display); color: var(--color-primary);"
              >
                {stat.numero}
              </p>
              <p class="text-sm" style="color: var(--color-text-muted);">
                {stat.label}
              </p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
  <!-- Sección: Publicaciones científicas -->
  <section style="background: var(--color-neutral-light);" class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <SectionTitle
        title="Publicaciones científicas"
        subtitle="Investigación"
      />

      <div class="space-y-4 mt-2">
        {[
          {
            titulo: 'Heartworm adulticide treatment: a tropical perspective',
            revista: 'Parasites & Vectors — Springer Nature',
            href: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC10141906/',
          },
          {
            titulo: 'First report of phaeohyphomycosis caused by Phialophora americana in a domestic cat from Argentina',
            revista: 'Journal of Feline Medicine and Surgery',
            href: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC8908401/',
          },
          {
            titulo: 'First identification of Strongyloides stercoralis infection in a pet dog in Argentina',
            revista: 'Parasites & Vectors — Springer Nature',
            href: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC10605978/',
          },
          {
            titulo: 'Feline tuberculosis due to Mycobacterium bovis: case series from Buenos Aires, Argentina',
            revista: 'Journal of Feline Medicine and Surgery',
            href: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC13009748/',
          },
        ].map((pub, i) => (
          <a
            href={pub.href}
            target="_blank"
            rel="noopener noreferrer"
            class="reveal flex gap-4 p-5 bg-white transition-shadow hover:shadow-md"
            style={`border-radius: var(--radius); box-shadow: var(--shadow); text-decoration: none; transition-delay: ${i * 0.1}s;`}
          >
            <div class="shrink-0 mt-0.5">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold leading-snug" style="color: var(--color-text);">{pub.titulo}</p>
              <p class="text-xs mt-1" style="color: var(--color-text-muted);">{pub.revista}</p>
            </div>
            <div class="ml-auto shrink-0 self-center">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>
