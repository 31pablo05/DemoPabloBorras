---
// pages/veterinarios/index.astro — Hub para veterinarios con 3 subsecciones y datos de autoridad
import Layout from '../../layouts/Layout.astro';
import SectionTitle from '../../components/ui/SectionTitle.astro';
import Button from '../../components/ui/Button.astro';
import PodcastsMNV from '../../components/veterinarios/PodcastsMNV.astro';

const subsecciones = [
  {
    href: '/veterinarios/interconsultas',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
    </svg>`,
    titulo: 'Interconsultas clínicas',
    descripcion: 'Segunda opinión especializada para casos complejos. Análisis detallado con enfoque evidence-based.',
    cta: 'Ver interconsultas',
  },
  {
    href: '/veterinarios/capacitaciones',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
      <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
    </svg>`,
    titulo: 'Capacitaciones',
    descripcion: 'Enfermedades vectoriales, infectología canina y felina, zoonosis y parasitología. Presenciales, online e híbridas. Charlas, workshops, jornadas y congresos.',
    cta: 'Ver capacitaciones',
  },
  {
    href: '/veterinarios/libro',
    icon: `<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
    </svg>`,
    titulo: 'Libro técnico',
    descripcion: 'Manual Práctico de Enfermedades Infecciosas y Parasitarias en el Perro. Publicado por Multimedica Ediciones Veterinarias. Herramienta de referencia clínica basada en evidencia científica.',
    cta: 'Ver el libro',
  },
];

const stats = [
  { numero: '+15',  label: 'Años de experiencia clínica' },
  { numero: '+30K', label: 'Seguidores en Instagram' },
  { numero: '+8',   label: 'Países donde disertó' },
  { numero: '+4',  label: 'Artículos científicos publicados' },
];
---

<Layout
  title="Para veterinarios — Interconsultas, Capacitaciones y Libro | Pablo Borrás"
  description="Interconsultas clínicas especializadas en infectología, capacitaciones en enfermedades vectoriales y libro técnico para médicos veterinarios. Por Pablo Borrás MSc."
  heroImage="/imagenes/heros/mendoza.jpg"
>

  <!-- Hero secundario -->
  <section
    class="py-20"
    style="min-height: 680px; display: flex; align-items: center; background: linear-gradient(135deg, rgba(4,13,78,0.78) 0%, rgba(2,6,24,0.85) 100%), url('/imagenes/heros/mendoza.jpg') center 60% / cover no-repeat;"
  >
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div
        class="inline-block text-xs font-semibold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6"
        style="background: rgba(24,128,201,0.12); color: var(--color-accent-light); border: 1px solid rgba(24,128,201,0.28);"
      >
        Espacio exclusivo para profesionales
      </div>
      <h1
        class="text-4xl md:text-5xl font-bold text-white mb-4"
        style="font-family: var(--font-display);"
      >
        Para veterinarios y profesionales
      </h1>
      <p class="text-white/75 text-lg max-w-2xl mx-auto">
        Herramientas diseñadas para elevar el estándar de tu ejercicio profesional: interconsultas, formación continua y material de referencia clínica.
      </p>
    </div>
  </section>

  <!-- 3 Cards de subsecciones -->
  <section style="background: var(--color-neutral-light);" class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

      <SectionTitle
        title="¿Qué necesitás?"
        subtitle="Servicios para colegas"
        centered={true}
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-2">
        {subsecciones.map(sub => (
          <a
            href={sub.href}
            class="card-lift group block bg-white rounded-2xl p-8 no-underline"
            style="border-radius: var(--radius); box-shadow: var(--shadow); text-decoration: none; border-top: 3px solid transparent; transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;"
            onmouseover="this.style.borderTopColor='var(--color-accent)'"
            onmouseout="this.style.borderTopColor='transparent'"
          >
            <div
              class="mb-5 w-14 h-14 flex items-center justify-center rounded-xl"
              style="color: var(--color-accent); background: rgba(24,128,201,0.08);"
              set:html={sub.icon}
            />
            <h2
              class="text-xl font-bold mb-3"
              style="font-family: var(--font-display); color: var(--color-text);"
            >
              {sub.titulo}
            </h2>
            <p class="text-sm leading-relaxed mb-6" style="color: var(--color-text-muted);">
              {sub.descripcion}
            </p>
            <span class="text-sm font-semibold group-hover:underline" style="color: var(--color-accent);">
              {sub.cta} →
            </span>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- Bloque de autoridad con stats -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Texto de autoridad -->
        <div>
          <SectionTitle
            title="Trayectoria que respalda"
            subtitle="Autoridad clínica"
          />
          <p class="text-base leading-relaxed mb-4" style="color: var(--color-text-muted);">
            Médico Veterinario egresado de la Universidad de Buenos Aires. Especialista
            en Enfermedades Infecciosas y Parasitarias (CPHV) y Magíster en Prevención y
            Control de Zoonosis (UNNOBA–ANLIS). Editor asociado de <em>Parasites and Vectors</em>
            (Springer Nature). Miembro del TroCCAP Council e ISCAID. Colaborador del
            servicio de Zoopatología del Hospital Francisco J. Muñiz. Actualmente
            cursando el Máster en Medicina Interna de Pequeños Animales en la
            Universidad Autónoma de Barcelona (España). Docente, investigador y speaker
            internacional con presencia en congresos en Argentina, Ecuador, Colombia,
            Uruguay, Brasil, Paraguay, España y Países Bajos.
          </p>
          <ul class="space-y-1.5 text-sm mb-8" style="color: var(--color-text-muted);">
            <li class="flex items-start gap-2"><span style="color: var(--color-accent);">&#9656;</span> Editor asociado de <em>Parasites &amp; Vectors</em> — Springer Nature</li>
            <li class="flex items-start gap-2"><span style="color: var(--color-accent);">&#9656;</span> Colaborador del servicio de Zoopatología, Hospital Francisco J. Muñiz</li>
            <li class="flex items-start gap-2"><span style="color: var(--color-accent);">&#9656;</span> Actualmente cursando el Máster en Medicina Interna — Fac. Veterinaria, UAB (España)</li>
            <li class="flex items-start gap-2"><span style="color: var(--color-accent);">&#9656;</span> Miembro de TroCCAP, ISCAID y ESCCAP</li>
          </ul>

          <!-- Membresías y reconocimientos -->
          <div class="pt-5" style="border-top: 1px solid #E5EAED;">
            <p class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: var(--color-text-muted);">Membresías y reconocimientos</p>
            <div class="flex flex-wrap gap-2">

              <!-- TroCCAP — azul -->
              <a
                href="https://www.troccap.com"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-opacity hover:opacity-80"
                style="border-radius: 8px; background: #EEF4FF; color: #1849A9; border: 0.5px solid #BDCFFA; text-decoration: none;"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
                TroCCAP Council Scientific Member
              </a>

              <!-- ABCD — verde -->
              <a
                href="https://www.abcdcatsvets.org"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-opacity hover:opacity-80"
                style="border-radius: 8px; background: #F0FDF4; color: #166534; border: 0.5px solid #86EFAC; text-decoration: none;"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                </svg>
                ABCD cats &amp; vets Europe
              </a>

              <!-- ISCAID — azul medio -->
              <a
                href="https://www.iscaid.org"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-opacity hover:opacity-80"
                style="border-radius: 8px; background: #EFF6FF; color: #1D4ED8; border: 0.5px solid #93C5FD; text-decoration: none;"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                ISCAID Member
              </a>

              <!-- ESCCAP — verde oscuro -->
              <a
                href="https://www.esccap.org"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-opacity hover:opacity-80"
                style="border-radius: 8px; background: #F0FDF4; color: #065F46; border: 0.5px solid #6EE7B7; text-decoration: none;"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                ESCCAP Member
              </a>

              <!-- Editor Parasites & Vectors — naranja -->
              <a
                href="https://link.springer.com/journal/13071"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-opacity hover:opacity-80"
                style="border-radius: 8px; background: #FFF7ED; color: #9A3412; border: 0.5px solid #FED7AA; text-decoration: none;"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                  <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                </svg>
                Editor — Parasites &amp; Vectors
              </a>

              <!-- AVEACA Premio — dorado -->
              <span
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium"
                style="border-radius: 8px; background: #FFFBEB; color: #92400E; border: 0.5px solid #FCD34D;"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                2º Premio mejor caso clínico — AVEACA 2025
              </span>

            </div>
          </div>
        </div>

        <!-- Imagen de Pablo -->
        <div class="flex flex-col gap-6">
          <!-- Imagen con stats superpuestos abajo -->
          <div class="img-desktop-rounded overflow-hidden relative" style="box-shadow: var(--shadow-lg);">
            <img
              src="/imagenes/perfil/pablo3.jpg"
              alt="Pablo Borrás — Médico Veterinario"
              class="w-full object-cover object-top img-desktop-rounded"
            />

            <!-- Stats overlay translúcido en la parte inferior -->
            <div
              class="absolute bottom-0 left-0 right-0"
              style="
                background: linear-gradient(to top, rgba(4,13,78,0.82) 0%, rgba(4,13,78,0.55) 60%, transparent 100%);
                backdrop-filter: blur(6px);
                -webkit-backdrop-filter: blur(6px);
                padding: 2rem 1.5rem 1.5rem;
              "
            >
              <div class="grid grid-cols-2 gap-3">
                {stats.map(stat => (
                <div class="stat-card text-center">
                  <p class="stat-number text-2xl font-bold text-white" style="font-family: var(--font-display);">
                    {stat.numero}
                  </p>
                  <p class="text-xs text-white/75 leading-tight mt-0.5">
                    {stat.label}
                  </p>
                </div>
                ))}
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>
  <!-- Sección: Publicaciones científicas -->
  <section style="background: var(--color-neutral-light);" class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <SectionTitle
        title="Publicaciones científicas"
        subtitle="Investigación y ciencia"
      />

      <div class="divide-y" style="border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); background: #fff;">
        {[
          {
            titulo: 'Heartworm adulticide treatment: a tropical perspective',
            revista: 'Parasites &amp; Vectors — Springer Nature',
            año: '2023',
            href: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC10141906/',
            pdf: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC10141906/pdf/13071_2023_Article_5690.pdf',
          },
          {
            titulo: 'First report of phaeohyphomycosis caused by Phialophora americana in a domestic cat from Argentina',
            revista: 'Journal of Feline Medicine and Surgery — SAGE Journals',
            año: '2022',
            href: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC8908401/',
            pdf: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC8908401/pdf/10.1177_20551169221077611.pdf',
          },
          {
            titulo: 'First identification of Strongyloides stercoralis infection in a pet dog in Argentina, using integrated diagnostic approaches',
            revista: 'Parasites &amp; Vectors — Springer Nature',
            año: '2023',
            href: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC10605978/',
            pdf: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC10605978/pdf/13071_2023_Article_6022.pdf',
          },
          {
            titulo: 'Feline tuberculosis due to Mycobacterium bovis: case series with clinical course, genotyping and therapeutic outcomes from Buenos Aires, Argentina',
            revista: 'Journal of Feline Medicine and Surgery — SAGE Journals',
            año: '2026',
            href: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC13009748/',
            pdf: 'https://pmc.ncbi.nlm.nih.gov/articles/PMC13009748/pdf/10.1177_20551169261427980.pdf',
          },
        ].map((pub, i) => (
          <div
            class="reveal flex gap-4 p-5 transition-colors hover:bg-neutral-50"
            style={`transition-delay: ${i * 0.1}s;`}
          >
            <div class="shrink-0 mt-0.5 text-lg">&#128196;</div>
            <div class="flex-1 min-w-0">
              <a
                href={pub.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-semibold leading-snug transition-colors hover:underline"
                style="color: var(--color-primary); text-decoration: none; display: block;"
                onmouseover="this.style.color='var(--color-accent)'"
                onmouseout="this.style.color='var(--color-primary)'"
              >
                {pub.titulo}
              </a>
              <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                <p class="text-xs" style="color: var(--color-text-muted);" set:html={pub.revista} />
                <span
                  class="inline-block px-1.5 py-0.5 rounded text-xs font-semibold"
                  style="background: rgba(24,128,201,0.10); color: var(--color-accent);"
                >
                  {pub.año}
                </span>
              </div>
            </div>
            <div class="ml-auto shrink-0 self-center flex items-center gap-2">
              <a
                href={pub.pdf}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 px-2.5 py-1 rounded text-xs font-semibold transition-colors hover:opacity-80"
                style="background: rgba(220,38,38,0.08); color: #DC2626; border: 1px solid rgba(220,38,38,0.2); text-decoration: none; white-space: nowrap;"
                title="Descargar PDF"
              >
                PDF
              </a>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <PodcastsMNV />

  <!-- Sección: Recursos y organizaciones de referencia -->
  <section class="py-14 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest mb-5 text-center" style="color: var(--color-text-muted);">Recursos y organizaciones de referencia</p>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          { label: 'TroCCAP', href: 'https://www.troccap.com' },
          { label: 'ABCD cats &amp; vets', href: 'https://www.abcdcatsvets.org' },
          { label: 'CAPC', href: 'https://capcvet.org' },
          { label: 'ESCCAP', href: 'https://www.esccap.org' },
          { label: 'ISCAID', href: 'https://www.iscaid.org' },
          { label: 'Parasites &amp; Vectors', href: 'https://link.springer.com/journal/13071' },
          { label: 'JVIM', href: 'https://academic.oup.com/jvim' },
        ].map(r => (
          <a
            href={r.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 text-xs font-medium transition-colors"
            style="border-radius: var(--radius); border: 1px solid #D1D5DB; color: var(--color-text-muted); text-decoration: none; background: var(--color-neutral-light);"
            set:html={r.label}
          />
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .img-desktop-rounded {
    border-radius: 0.75rem;
  }

  @media (min-width: 768px) {
    .img-desktop-rounded {
      border-radius: 2rem;
    }
  }

  .stat-card {
    padding: 0.5rem;
    border-radius: 0.75rem;
    cursor: default;
    transition: transform 0.25s ease, background 0.25s ease;
  }

  .stat-card:hover {
    transform: translateY(-4px) scale(1.05);
    background: rgba(255, 255, 255, 0.10);
  }

  .stat-card:hover .stat-number {
    color: var(--color-accent-light);
    transition: color 0.25s ease;
  }

  .stat-number {
    transition: color 0.25s ease;
  }
</style>