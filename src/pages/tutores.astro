  .media-card:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important;
  }

  .social-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2) !important;
  }

  .vet-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(24,128,201,0.2) !important;
  }

  .vet-card:hover .vet-image {
    transform: scale(1.05);
  }

  .turno-btn:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 10px 32px rgba(0,0,0,0.3) !important;
  }

  .vertical-video-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(24,128,201,0.15) !important;
  }

  .video-facade-container:hover .play-button-overlay {
    background: rgba(4,13,78,0.5);
  }

  .video-facade-container:hover .play-button-overlay > div {
    transform: scale(1.1);
  }

  /* Responsive mejorado */
  @media (max-width: 640px) {
    .feature-card {
      padding: 1.5rem !important;
    }
    
    .media-card {
      padding: 1rem !important;
    }

    .vet-card {
      padding: 1.25rem !important;
    }

    .turno-btn {
      width: 100%;
      justify-content: center;
    }
  }

  /* Animación reveal al hacer scroll */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Animación reveal on scroll
  const reveals = document.querySelectorAll('.reveal');
  
  const revealOnScroll = () => {
    reveals.forEach(element => {
      const elementTop = element.getBoundingClientRect().top;
      const windowHeight = window.innerHeight;
      
      if (elementTop < windowHeight - 80) {
        element.classList.add('active');
      }
    });
  };

  // Initial check
  revealOnScroll();
  
  // On scroll
  window.addEventListener('scroll', revealOnScroll);

  // Manejo de videos verticales con facade
  const videoFacades = document.querySelectorAll('.video-facade-container');
  
  videoFacades.forEach((facade) => {
    facade.addEventListener('click', function(this: HTMLElement) {
      const videoSrc = this.getAttribute('data-video-src');
      
      // Crear elemento video
      const videoElement = document.createElement('video');
      videoElement.src = videoSrc || '';
      videoElement.controls = true;
      videoElement.autoplay = true;
      videoElement.playsInline = true;
      videoElement.preload = 'auto';
      videoElement.style.width = '100%';
      videoElement.style.height = '100%';
      videoElement.style.objectFit = 'cover';
      
      // Reemplazar el facade por el video
      this.innerHTML = '';
      this.appendChild(videoElement);
      this.style.cursor = 'default';
    });
  });
</script>
