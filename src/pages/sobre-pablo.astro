        <p class="mt-4 text-base max-w-xl mx-auto" style="color: var(--color-text-muted);">
          Membresías, colaboraciones y premios que ubican a Pablo en la primera línea de la infectología veterinaria global.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {ciencia.map((item, index) => {
          // Colores por categoría
          const colores = [
            '#1880c9', // Editor asociado
            '#040d4e', // TroCCAP Council
            '#183b7f', // ABCD Cats & Vets Europe
            '#5ba8e0', // ISCAID
            '#183b7f', // Hospital Francisco J. Muñiz
            '#16a34a', // Premio AVEACA 2025
          ];
          const colorCategoria = colores[index];
          const esPremio = index === 5;

          // Convertir hex a rgba con opacidad para el fondo del ícono
          const hexToRgba = (hex: string, alpha: number) => {
            const r = parseInt(hex.slice(1, 3), 16);
            const g = parseInt(hex.slice(3, 5), 16);
            const b = parseInt(hex.slice(5, 7), 16);
            return `rgba(${r}, ${g}, ${b}, ${alpha})`;
          };

          return (
            <div
              class="ciencia-card"
              style={`
                background: var(--color-neutral-light);
                border: 1px solid #DDE8F5;
                border-top: 3px solid ${colorCategoria};
                border-radius: 16px;
                padding: 24px;
                position: relative;
                transition: transform 0.2s ease, box-shadow 0.2s ease;
              `}
            >
              {esPremio && (
                <span
                  style="
                    position: absolute;
                    top: 20px;
                    right: 20px;
                    display: inline-flex;
                    align-items: center;
                    gap: 4px;
                    font-size: 0.65rem;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 0.03em;
                    color: #166534;
                    background: #dcfce7;
                    border-radius: 999px;
                    padding: 4px 10px;
                  "
                >
                  ★ Premio
                </span>
              )}

              <div
                style={`
                  width: 48px;
                  height: 48px;
                  border-radius: 12px;
                  background: ${hexToRgba(colorCategoria, 0.12)};
                  border: 1px solid ${hexToRgba(colorCategoria, 0.25)};
                  display: flex;
                  align-items: center;
                  justify-content: center;
                  color: ${colorCategoria};
                  margin-bottom: 14px;
                `}
              >
                <div style={`color: ${colorCategoria};`} set:html={item.icono.replace('stroke="currentColor"', `stroke="${colorCategoria}"`)} />
              </div>

              <p
                class="font-bold text-sm mb-0.5"
                style="color: var(--color-text); font-family: var(--font-display);"
              >
                {item.titulo}
              </p>

              <p
                class="text-xs font-semibold mb-3"
                style={`
                  color: ${colorCategoria};
                  text-transform: uppercase;
                  letter-spacing: 0.03em;
                `}
              >
                {item.detalle}
              </p>

              <p
                class="text-sm leading-relaxed"
                style="color: var(--color-text-muted);"
              >
                {item.descripcion}
              </p>
            </div>
          );
        })}
