                    {!esActivo && <span style="width: 4px; height: 4px; border-radius: 50%; background: #1880c9;"></span>}
                    {item.año}
                  </span>

                  <h3
                    style="
                      font-family: var(--font-display);
                      font-weight: 700;
                      font-size: 15px;
