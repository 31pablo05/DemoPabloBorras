---
// pages/sobre-pablo.astro — Página completa "Acerca de Pablo Borrás"
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';

const formacion = [
  {
    año: '2005–2011',
    titulo: 'Médico Veterinario',
    institucion: 'Universidad de Buenos Aires (UBA)',
    descripcion: 'Facultad de Ciencias Veterinarias. Formación de grado con orientación en clínica de pequeños animales.',
  },
  {
    año: '2013–2016',
    titulo: 'Especialista en Enfermedades Infecciosas y Parasitarias',
    institucion: 'CPHV — Centro Profesional de Herrmienta Veterinaria',
    descripcion: 'Especialización con foco en infectología y parasitología clínica canina y felina.',
  },
  {
    año: '2017–2020',
    titulo: 'Magíster en Prevención y Control de Zoonosis',
    institucion: 'UNNOBA – ANLIS',
    descripcion: 'Maestría conjunta entre la Universidad Nacional del Noroeste de la Provincia de Buenos Aires y el ANLIS. Enfoque en epidemiología, salud pública veterinaria y enfermedades zoonóticas.',
  },
  {
    año: '2024–Actualidad',
    titulo: 'Máster en Medicina Interna de Pequeños Animales',
    institucion: 'Universidad Autónoma de Barcelona (España)',
    descripcion: 'Formación de posgrado en medicina interna avanzada. Cursando actualmente con modalidad internacional.',
  },
];

const ciencia = [
  {
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    titulo: 'Editor asociado',
    detalle: 'Parasites & Vectors — Springer Nature',
    descripcion: 'Revista científica internacional de referencia en parasitología y enfermedades vectoriales.',
  },
  {
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    titulo: 'TroCCAP Council',
    detalle: 'Scientific Member',
    descripcion: 'Consejo científico de los Consensos de Parasitología Tropical en Animales de Compañía para Asia, África y América Latina.',
  },
  {
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    titulo: 'ABCD Cats & Vets Europe',
    detalle: 'Colaborador científico',
    descripcion: 'Plataforma europea de guías de vacunación y manejo de enfermedades infecciosas felinas basadas en evidencia.',
  },
  {
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6"/><path d="M9 12h6"/><path d="M9 15h4"/></svg>`,
    titulo: 'ISCAID',
    detalle: 'Miembro activo',
    descripcion: 'International Society for Companion Animal Infectious Diseases. Red internacional de infectólogos de pequeños animales.',
  },
  {
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    titulo: 'Hospital Francisco J. Muñiz',
    detalle: 'Colaborador — Servicio de Zoopatología',
    descripcion: 'Colaboración activa con el principal hospital de enfermedades infecto-contagiosas de Argentina.',
  },
  {
    icono: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8.21 13.89L7 23l5-3 5 3-1.21-9.12"/><path d="M15 7a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path d="M12 22v-3"/></svg>`,
    titulo: '2° Premio AVEACA 2025',
    detalle: 'Mejor caso clínico — Buenos Aires',
    descripcion: 'Primer reporte de Schizophyllum commune en perro en América Latina. Caso de osteomielitis micótica diseminada.',
  },
];

const congresos = [
  { pais: 'Argentina',       foto: '/imagenes/congresos/aveaca-buenos-aires-2025.jpg',    nombre: 'AVEACA 2025 — Buenos Aires' },
  { pais: 'Colombia',        foto: '/imagenes/congresos/medellin-colombia-2025.jpg',       nombre: 'Congreso Internacional — Medellín' },
  { pais: 'Ecuador',         foto: '/imagenes/congresos/cvdl-guayaquil-2025.jpg',          nombre: 'CVDL — Guayaquil' },
  { pais: 'Paraguay',        foto: '/imagenes/congresos/idexx-asuncion-2025.jpg',          nombre: 'IDEXX Speaker — Asunción' },
  { pais: 'Brasil',          foto: '/imagenes/congresos/waavp-curitiba-2025.jpg',          nombre: 'WAAVP — Curitiba' },
  { pais: 'Países Bajos',    foto: '/imagenes/congresos/ecvim-maastricht-2025.jpg',        nombre: 'ECVIM-CA — Maastricht' },
  { pais: 'Argentina',       foto: '/imagenes/congresos/civi-iguazu-2025.jpg',             nombre: 'CIVI — Puerto Iguazú' },
  { pais: 'Argentina',       foto: '/imagenes/congresos/mendoza-2025.jpg',                 nombre: 'Congreso Regional — Mendoza' },
];

const tematicas = [
  'Enfermedades vectoriales (Ehrlichia, Babesia, Anaplasma, Dirofilaria, Leishmania, Hepatozoon)',
  'Infectología canina y felina',
  'Zoonosis: brucelosis canina, TBC bovina en gatos, Strongyloides stercoralis',
  'Parasitología con diagnóstico molecular',
  'Moquillo canino y leptospirosis',
  'Panleucopenia felina y toxoplasmosis',
  'Dirofilariosis canina (incluyendo heat treatment)',
  'Vacunación en caninos: protocolos basados en evidencia',
];
---

<Layout
  title="Sobre Pablo Borrás — Veterinario, Speaker y Autor"
  description="Conocé en profundidad a Pablo Borrás: su trayectoria académica, actividad científica internacional, congresos en 8 países y especialización en enfermedades infecciosas y parasitarias."
>

  <!-- ── HERO ── -->
  <section
    style="
      position: relative;
      min-height: 680px;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
      background: linear-gradient(160deg, #040d4e 0%, #0d2466 40%, #0a1e55 100%);
    "
  >
    <!-- Foto de fondo con overlay -->
    <div
      style="
        position: absolute;
        inset: 0;
        background: url('/imagenes/perfil/pablo3.jpg') center 20% / cover no-repeat;
        opacity: 0.22;
      "
      aria-hidden="true"
    ></div>

    <!-- Gradiente oscuro abajo -->
    <div
      style="position: absolute; bottom: 0; left: 0; right: 0; height: 55%; background: linear-gradient(to top, rgba(4,13,78,0.95), transparent);"
      aria-hidden="true"
    ></div>

    <div
      class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-28 w-full"
      style="position: relative; z-index: 1;"
    >
      <div class="max-w-3xl">
        <span
          class="inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-6"
          style="background: rgba(24,128,201,0.18); color: var(--color-accent-light); border: 1px solid rgba(24,128,201,0.35);"
        >
          Médico Veterinario MSc · Speaker Internacional · Autor
        </span>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6"
          style="font-family: var(--font-display); line-height: 1.15;"
        >
          Pablo Borrás
        </h1>
        <p class="text-white/75 text-lg max-w-xl leading-relaxed">
          Especialista en enfermedades infecciosas y parasitarias de perros y gatos.
          Docente, investigador y voz de referencia en infectología veterinaria de habla hispana.
        </p>
      </div>
    </div>
  </section>

  <!-- ── BIO + FOTO ── -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Foto -->
        <div class="order-2 lg:order-1">
          <div style="border-radius: 18px; overflow: hidden; box-shadow: var(--shadow-lg); max-height: 560px;">
            <img
              src="/imagenes/perfil/pablo1.jpg"
              alt="Pablo Borrás — Médico Veterinario especialista en infectología"
              class="w-full object-cover object-top"
              style="border-radius: 18px; max-height: 560px;"
              width="560"
              height="560"
              loading="eager"
            />
          </div>
          <!-- Credencial -->
          <div
            style="
              margin-top: 16px;
              display: flex;
              align-items: center;
              gap: 10px;
              background: var(--color-neutral-light);
              border: 1px solid #c8d8f0;
              border-radius: 10px;
              padding: 12px 16px;
            "
          >
            <span
              style="width: 8px; height: 8px; border-radius: 50%; background: #4ade80; flex-shrink: 0;"
              aria-hidden="true"
            ></span>
            <p style="font-family: var(--font-body); font-size: 0.8rem; color: var(--color-text-muted); margin: 0; line-height: 1.5;">
              Editor asociado · <em>Parasites &amp; Vectors</em> — Springer Nature &nbsp;·&nbsp; Buenos Aires, Argentina
            </p>
          </div>
        </div>

        <!-- Texto bio -->
        <div class="order-1 lg:order-2">
          <span
            class="inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-5"
            style="background: rgba(24,128,201,0.1); color: var(--color-accent); border: 1px solid rgba(24,128,201,0.25);"
          >
            Quién es
          </span>
          <h2
            class="text-3xl md:text-4xl font-bold mb-6"
            style="font-family: var(--font-display); color: var(--color-text); line-height: 1.2;"
          >
            Una trayectoria construida sobre ciencia y compromiso
          </h2>
          <div style="color: var(--color-text-muted); font-size: 1rem; line-height: 1.85;" class="space-y-4">
            <p>
              Pablo Borrás es Médico Veterinario egresado de la Universidad de Buenos Aires, Especialista
              en Enfermedades Infecciosas y Parasitarias (CPHV) y Magíster en Prevención y Control de
              Zoonosis (UNNOBA–ANLIS). Actualmente cursa el Máster en Medicina Interna de Pequeños
              Animales en la Universidad Autónoma de Barcelona.
            </p>
            <p>
              A lo largo de más de 15 años de carrera, construyó un perfil único que combina la clínica
              diaria con la investigación científica, la docencia y la comunicación. Ese cruce entre
              rigor académico y capacidad de transmitir es lo que define su forma de ejercer y enseñar.
            </p>
            <p>
              Ha disertado en congresos internacionales en Argentina, Colombia, Ecuador, Uruguay, Brasil,
              Paraguay, España y Países Bajos. Es colaborador del Servicio de Zoopatología del Hospital
              Francisco J. Muñiz, editor asociado de <em>Parasites & Vectors</em> (Springer Nature) y
              miembro activo del TroCCAP Council, ABCD Cats & Vets Europe e ISCAID.
            </p>
            <p>
              En 2025, obtuvo el 2° Premio al mejor caso clínico en AVEACA por el primer reporte de
              <em>Schizophyllum commune</em> en perro en América Latina. Ese mismo año fue speaker
              oficial del lanzamiento de SNAP Tests IDEXX en Asunción, Paraguay.
            </p>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-2 mt-8 pt-8" style="border-top: 1px solid #E5EAED;">
            {[
              { n: '+15', l: 'Años de experiencia clínica' },
              { n: '+30K', l: 'Seguidores en Instagram' },
              { n: '+8', l: 'Países donde disertó' },
              { n: '+4', l: 'Artículos científicos' },
            ].map((s, i) => (
              <div
                class="p-4"
                style={[
                  i % 2 === 1 ? 'border-left: 1px solid #c8d8f0;' : '',
                  i >= 2      ? 'border-top: 1px solid #c8d8f0;'  : '',
                ].join(' ')}
              >
                <p class="text-2xl font-bold leading-none" style="font-family: var(--font-display); color: var(--color-accent);">{s.n}</p>
                <p class="text-xs mt-1" style="color: var(--color-text-muted);">{s.l}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── FORMACIÓN ACADÉMICA ── -->
  <section style="background: var(--color-neutral-light);" class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span
          class="inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-4"
          style="background: rgba(24,128,201,0.1); color: var(--color-accent); border: 1px solid rgba(24,128,201,0.25);"
        >
          Trayectoria académica
        </span>
        <h2
          class="text-3xl md:text-4xl font-bold"
          style="font-family: var(--font-display); color: var(--color-text);"
        >
          Formación y posgrados
        </h2>
      </div>

      <!-- Timeline -->
      <div style="position: relative;">
        <!-- Línea vertical -->
        <div
          style="position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: linear-gradient(to bottom, var(--color-accent), rgba(24,128,201,0.2)); margin-left: 20px;"
          aria-hidden="true"
        ></div>

        <div class="space-y-10" style="padding-left: 56px;">
          {formacion.map((item) => (
            <div style="position: relative;">
              <!-- Punto en la línea -->
              <div
                style="position: absolute; left: -48px; top: 6px; width: 16px; height: 16px; border-radius: 50%; background: var(--color-accent); border: 3px solid white; box-shadow: 0 0 0 3px rgba(24,128,201,0.2);"
                aria-hidden="true"
              ></div>
              <div
                style="
                  background: white;
                  border: 1px solid #DDE8F5;
                  border-radius: 14px;
                  padding: 20px 24px;
                  box-shadow: var(--shadow);
                "
              >
                <span
                  style="
                    display: inline-block;
                    font-family: var(--font-body);
                    font-size: 0.7rem;
                    font-weight: 700;
                    text-transform: uppercase;
                    letter-spacing: 0.08em;
                    color: var(--color-accent);
                    background: rgba(24,128,201,0.08);
                    border: 1px solid rgba(24,128,201,0.2);
                    border-radius: 20px;
                    padding: 3px 10px;
                    margin-bottom: 8px;
                  "
                >{item.año}</span>
                <h3
                  class="font-bold text-base mb-1"
                  style="font-family: var(--font-display); color: var(--color-text);"
                >
                  {item.titulo}
                </h3>
                <p
                  class="text-sm font-semibold mb-2"
                  style="color: var(--color-accent);"
                >
                  {item.institucion}
                </p>
                <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
                  {item.descripcion}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── ACTIVIDAD CIENTÍFICA ── -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <span
          class="inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-4"
          style="background: rgba(24,128,201,0.1); color: var(--color-accent); border: 1px solid rgba(24,128,201,0.25);"
        >
          Ciencia y reconocimientos
        </span>
        <h2
          class="text-3xl md:text-4xl font-bold"
          style="font-family: var(--font-display); color: var(--color-text);"
        >
          Actividad científica internacional
        </h2>
        <p class="mt-4 text-base max-w-xl mx-auto" style="color: var(--color-text-muted);">
          Membresías, colaboraciones y premios que ubican a Pablo en la primera línea de la infectología veterinaria global.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {ciencia.map((item) => (
          <div
            style="
              background: var(--color-neutral-light);
              border: 1px solid #DDE8F5;
              border-radius: 16px;
              padding: 24px;
              transition: transform 0.2s, box-shadow 0.2s;
            "
            onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='var(--shadow-lg)';"
            onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';"
          >
            <div
              style="
                width: 48px;
                height: 48px;
                border-radius: 12px;
                background: rgba(24,128,201,0.1);
                border: 1px solid rgba(24,128,201,0.2);
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--color-accent);
                margin-bottom: 14px;
              "
              set:html={item.icono}
            ></div>
            <p class="font-bold text-sm mb-0.5" style="color: var(--color-text); font-family: var(--font-display);">{item.titulo}</p>
            <p class="text-xs font-semibold mb-3" style="color: var(--color-accent);">{item.detalle}</p>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{item.descripcion}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TEMÁTICAS ── -->
  <section style="background: linear-gradient(135deg, #040d4e 0%, #0d2466 50%, #040d4e 100%);" class="py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span
          class="inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-4"
          style="background: rgba(24,128,201,0.18); color: var(--color-accent-light); border: 1px solid rgba(24,128,201,0.35);"
        >
          Especialidades
        </span>
        <h2
          class="text-3xl md:text-4xl font-bold text-white"
          style="font-family: var(--font-display);"
        >
          Áreas de expertise
        </h2>
        <p class="mt-4 text-white/65 max-w-lg mx-auto">
          Temáticas en las que Pablo es referente y sobre las cuales da charlas, capacitaciones y atiende interconsultas.
        </p>
      </div>

      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {tematicas.map((t) => (
          <li
            style="
              display: flex;
              align-items: flex-start;
              gap: 10px;
              background: rgba(255,255,255,0.06);
              border: 1px solid rgba(255,255,255,0.1);
              border-radius: 10px;
              padding: 14px 16px;
            "
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              style="color: var(--color-accent-light); flex-shrink: 0; margin-top: 2px;"
              aria-hidden="true"
            >
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="text-sm text-white/80 leading-snug">{t}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ── GALERÍA CONGRESOS ── -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span
          class="inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full mb-4"
          style="background: rgba(24,128,201,0.1); color: var(--color-accent); border: 1px solid rgba(24,128,201,0.25);"
        >
          Presencia internacional
        </span>
        <h2
          class="text-3xl md:text-4xl font-bold"
          style="font-family: var(--font-display); color: var(--color-text);"
        >
          Speaker en +8 países
        </h2>
        <p class="mt-4 text-base max-w-lg mx-auto" style="color: var(--color-text-muted);">
          Argentina, Colombia, Ecuador, Uruguay, Brasil, Paraguay, España y Países Bajos.
          Una agenda internacional en constante expansión.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {congresos.map((c) => (
          <div
            style="
              position: relative;
              border-radius: 14px;
              overflow: hidden;
              aspect-ratio: 4/3;
              box-shadow: var(--shadow);
              transition: transform 0.25s, box-shadow 0.25s;
            "
            onmouseover="this.style.transform='scale(1.03)'; this.style.boxShadow='var(--shadow-lg)';"
            onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='var(--shadow)';"
          >
            <img
              src={c.foto}
              alt={c.nombre}
              style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
              loading="lazy"
              width="300"
              height="225"
            />
            <div
              style="
                position: absolute;
                bottom: 0; left: 0; right: 0;
                padding: 28px 12px 12px;
                background: linear-gradient(to top, rgba(4,13,78,0.85), transparent);
              "
            >
              <p
                style="
                  font-family: var(--font-body);
                  font-size: 0.65rem;
                  font-weight: 700;
                  color: white;
                  text-transform: uppercase;
                  letter-spacing: 0.05em;
                  margin: 0;
                  line-height: 1.3;
                "
              >{c.nombre}</p>
              <p style="font-size: 0.6rem; color: rgba(255,255,255,0.6); margin: 2px 0 0; font-family: var(--font-body);">{c.pais}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA FINAL ── -->
  <section style="background: var(--color-neutral-light); border-top: 1px solid #DDE8F5;" class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2
        class="text-3xl md:text-4xl font-bold mb-4"
        style="font-family: var(--font-display); color: var(--color-text);"
      >
