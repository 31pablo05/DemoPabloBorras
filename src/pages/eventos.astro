---
// pages/eventos.astro — Agenda completa de eventos
import Layout from '../layouts/Layout.astro';
import AgendaEventos from '../components/eventos/AgendaEventos.astro';
---

<Layout
  title="Congresos y eventos veterinarios — Pablo Borrás Speaker Internacional"
  description="Agenda de participación de Pablo Borrás en congresos veterinarios nacionales e internacionales. ECVIM, WAAVP, AVEACA y más. Solicitar invitación como ponente."
>

  <!-- Hero de eventos -->
  <section
    class="py-20 text-center"
    style="min-height: 520px; display: flex; align-items: center; background: linear-gradient(135deg, rgba(4,13,78,0.78) 0%, rgba(2,6,24,0.85) 100%), url('/imagenes/heros/1.png') center 65% / cover no-repeat;"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-5xl mb-6">🗓</div>
      <h1
        class="text-4xl md:text-5xl font-bold text-white mb-4"
        style="font-family: var(--font-display);"
      >
        Agenda de eventos
      </h1>
      <p class="text-white/70 text-lg">
        Congresos, jornadas, workshops y simposios donde Pablo Borrás participa como speaker, trainer o panelista en todo el país.
      </p>
    </div>
  </section>

  <!-- Agenda completa (timeline) -->
  <AgendaEventos />

</Layout>
